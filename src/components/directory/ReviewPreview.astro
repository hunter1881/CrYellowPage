---
import TranslatedText from '@components/i18n/TranslatedText.astro'

interface Props {
  providerName?: string
  districtName?: string
  rating?: string
  reviewCount?: number
}

const {
  providerName = 'este proveedor',
  districtName = 'este distrito',
  rating = '4.8',
  reviewCount = 0,
} = Astro.props
---

<section class="civic-card mt-4 p-5">
  <div class="mb-3 flex items-center justify-between">
    <p class="civic-meta">
      <TranslatedText es={`Reseñas de clientes · ${reviewCount}`} en={`Client reviews · ${reviewCount}`} />
    </p>
    <button class="text-xs font-semibold text-canopy">
      <TranslatedText es="Ver todas" en="See all" />
    </button>
  </div>
  <div class="rounded-civic border border-rule-soft bg-surface-alt p-4">
    <div class="mb-2 flex items-center justify-between gap-3">
      <span class="text-sm font-semibold text-ink">Cliente local</span>
      <span class="font-mono text-[11px] uppercase tracking-[0.5px] text-ink-3">{districtName}</span>
    </div>
    <div class="mb-3 text-sm text-star">★★★★★ <span class="text-ink">{rating}</span></div>
    <p class="text-sm leading-6 text-ink-2">
      <TranslatedText
        es={`${providerName} respondió rápido, explicó el trabajo con claridad y atendió la zona de ${districtName} sin problema.`}
        en={`${providerName} replied quickly, explained the job clearly, and served the ${districtName} area without issues.`}
      />
    </p>
  </div>
  <p class="mt-3 text-xs leading-5 text-ink-3">
    <TranslatedText
      es="El módulo dinámico de reseñas usará Astro Server Islands cuando conectemos escrituras reales."
      en="The dynamic reviews module will use Astro Server Islands when real review writes are connected."
    />
  </p>
</section>

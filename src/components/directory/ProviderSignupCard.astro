---
import { t } from '@lib/i18n'

interface Props {
  compact?: boolean
}

const { compact = false } = Astro.props
---

<aside id="provider-signup" class={compact ? '' : 'order-2 md:order-1'}>
  <div
    class="relative overflow-hidden rounded-civic-lg p-5 text-white"
    style="background: #0E1F18;"
  >
    {/* Radial glow accent */}
    <div
      class="pointer-events-none absolute -right-10 -top-10 h-32 w-32 rounded-full"
      style="background: radial-gradient(circle, #16C97A25, transparent 70%);"
    ></div>

    <div
      class="relative mb-2 text-[11px] font-semibold uppercase tracking-[0.5px]"
      style="color: #16C97A;"
    >
      {t('signup.forProviders')}
    </div>
    <p class="relative mb-2.5 text-[18px] font-semibold leading-tight tracking-[-0.3px]">
      {t('signup.question')}
    </p>
    <p class="relative mb-4 text-[13px] leading-normal" style="color: rgba(255,255,255,.7);">
      {t('signup.description')}
    </p>
    <a
      href="/register-provider/"
      class="relative inline-flex items-center gap-1.5 rounded-full px-4 py-2.5 text-[13px] font-semibold no-underline transition-opacity hover:opacity-90"
      style="background: #16C97A; color: #0E1F18;"
    >
      {t('signup.cta')}
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2.5 6h7m-3-3 3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</aside>

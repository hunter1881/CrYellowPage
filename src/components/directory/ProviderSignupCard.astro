---
import Button from '@components/ui/Button.astro'
import { t } from '@lib/i18n'

interface Props {
  compact?: boolean
}

const { compact = false } = Astro.props
---

<aside id="provider-signup" class={compact ? '' : 'order-2 md:order-1'}>
  <div class="civic-meta border-b border-rule pb-2">{t('signup.forProviders')}</div>
  <div class="mt-4 rounded-civic border border-canopy bg-canopy-soft p-4">
    <p class="civic-meta text-canopy-ink">{t('signup.question')}</p>
    <p class="mt-2 text-sm leading-6 text-ink-2">
      {t('signup.description')}
    </p>
    <Button variant="primary" href="/register-provider/" class="mt-4">
      {t('signup.cta')}
    </Button>
  </div>
</aside>

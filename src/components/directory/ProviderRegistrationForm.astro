---
import { actions } from 'astro:actions'
import { t } from '@lib/i18n'
import type { Category } from '@lib/queries/categories'
import type { CantonWithDistricts } from '@lib/queries/geography'
import type { PaymentMethod } from '@lib/queries/paymentMethods'
import Button from '@components/ui/Button.astro'
import Checkbox from '@components/ui/Checkbox.astro'
import ChipSelect from '@components/ui/ChipSelect.astro'
import Input from '@components/ui/Input.astro'
import Textarea from '@components/ui/Textarea.astro'

interface Props {
  cantons: CantonWithDistricts[]
  categories: Category[]
  paymentMethods: PaymentMethod[]
  inputErrors?: Record<string, string[] | undefined>
}

const { cantons, categories, paymentMethods, inputErrors = {} } = Astro.props
const errorFor = (name: string) => inputErrors[name]?.join(', ')

const categoryOptions = categories.map((c) => ({
  value: c.id,
  label: `${c.icon_emoji ?? ''} ${c.name}`.trim(),
}))

const paymentOptions = paymentMethods.map((pm) => ({
  value: pm.slug,
  label: pm.name,
}))

const districtOptions = cantons.flatMap((canton) =>
  canton.districts.map((d) => ({
    d: d.name,
    c: canton.name,
    di: d.id,
  })),
)
---

<form class="civic-card grid gap-5 p-5" method="POST" action={actions.registerProvider}>
  <div>
    <p class="civic-meta">{t('form.applicationMeta')}</p>
    <h2 class="mt-2 text-xl font-semibold text-ink">
      {t('form.applicationTitle')}
    </h2>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <Input label={t('form.businessName')} name="businessName" required minlength="3" maxlength="120" error={errorFor('businessName')} />
    <Input label={t('form.contactPerson')} name="contactName" required minlength="3" maxlength="120" error={errorFor('contactName')} />
    <Input label="Email" name="email" type="email" required maxlength="160" error={errorFor('email')} />
    <Input label={t('form.phone')} name="phone" required type="tel" placeholder="8888-8888" error={errorFor('phone')} />
    <Input
      label={`WhatsApp`}
      name="whatsapp"
      type="tel"
      placeholder="+506 8888-8888"
      hint={t('common.optional')}
      error={errorFor('whatsapp')}
      class="md:col-span-2"
    />
  </div>

  <div class="grid gap-4">

    <district-autocomplete class="grid gap-1" data-options={JSON.stringify(districtOptions)}>
      <label class="text-sm font-semibold text-ink" for="district-text-input">
        {t('form.district')} <span class="text-clay">*</span>
      </label>
      <div class="relative">
        <input
          id="district-text-input"
          class="w-full rounded-civic border border-rule bg-surface px-3 py-2.5 text-sm font-semibold text-ink outline-none placeholder:font-normal placeholder:text-ink-3 focus:border-ink focus:ring-0"
          type="text"
          autocomplete="off"
          placeholder="Escriba un distrito o cantón…"
          data-district-text
          aria-autocomplete="list"
          aria-haspopup="listbox"
        />
        <ul
          class="absolute left-0 right-0 top-full z-50 mt-1 hidden max-h-56 overflow-y-auto rounded-civic border border-rule bg-surface shadow-civic-lg"
          data-district-dropdown
          role="listbox"
        ></ul>
      </div>
      <input type="hidden" name="districtId" data-district-id-input />
      {errorFor('districtId') && <span class="text-xs font-medium text-clay">{errorFor('districtId')}</span>}
    </district-autocomplete>

    <ChipSelect
      name="categoryIds"
      label={t('form.serviceCategories')}
      options={categoryOptions}
      max={4}
      required
      placeholder="Buscar categoría de servicio…"
      error={errorFor('categoryIds')}
    />

  <ChipSelect
    name="paymentMethodSlugs"
    label="Métodos de pago aceptados"
    options={paymentOptions}
    max={11}
    placeholder="Buscar método de pago…"
    error={errorFor('paymentMethodSlugs')}
  />
    <Textarea
      label={t('form.serviceDescription')}
      name="description"
      required
      minlength={30}
      maxlength={500}
      rows={5}
      error={errorFor('description')}
    />
  </div>
  <div class="grid gap-4 rounded-civic border border-rule bg-surface-alt p-4 md:grid-cols-2">
    <Input label={t('form.yearsActive')} name="yearsActive" type="number" value="1" />
    <Checkbox name="worksWeekends" value="true" label={t('form.worksWeekends')} variant="plain" class="self-end pb-2" />
  </div>

  <input name="sourceLocale" type="hidden" value="es" />
  <label class="hidden">
    Website
    <input name="website" tabindex="-1" autocomplete="off" />
  </label>

  <Button variant="primary" type="submit" full>
    {t('form.submit')}
  </Button>
</form>

<script>
  type DistrictOption = { d: string; c: string; di: string }

  function normalize(value: string): string {
    return value
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .replace(/[ñÑ]/g, 'n')
      .toLowerCase()
  }

  class DistrictAutocomplete extends HTMLElement {
    private options: DistrictOption[] = []
    private textInput!: HTMLInputElement
    private idInput!: HTMLInputElement
    private dropdown!: HTMLUListElement

    connectedCallback() {
      const text = this.querySelector<HTMLInputElement>('[data-district-text]')
      const id = this.querySelector<HTMLInputElement>('[data-district-id-input]')
      const dropdown = this.querySelector<HTMLUListElement>('[data-district-dropdown]')
      if (!text || !id || !dropdown) return
      this.textInput = text
      this.idInput = id
      this.dropdown = dropdown
      try {
        this.options = JSON.parse(this.dataset.options ?? '[]')
      } catch {
        this.options = []
      }
      this.textInput.addEventListener('input', this.handleInput)
      this.textInput.addEventListener('focus', this.handleFocus)
      this.textInput.addEventListener('blur', this.handleBlur)
    }

    private handleInput = () => {
      this.idInput.value = ''
      this.textInput.classList.remove('border-canopy')
      this.textInput.classList.add('border-rule')
      const q = normalize(this.textInput.value)
      if (!q) {
        this.dropdown.classList.add('hidden')
        return
      }
      this.renderDropdown(this.findMatches(q))
    }

    private handleFocus = () => {
      if (this.textInput.value && !this.idInput.value) {
        this.renderDropdown(this.findMatches(normalize(this.textInput.value)))
      }
    }

    private handleBlur = () => {
      window.setTimeout(() => this.dropdown.classList.add('hidden'), 150)
      if (this.textInput.value && !this.idInput.value) {
        this.textInput.value = ''
        this.textInput.classList.remove('border-canopy')
        this.textInput.classList.add('border-rule')
      }
    }

    private findMatches(q: string): DistrictOption[] {
      return this.options
        .filter((o) => normalize(o.d).includes(q) || normalize(o.c).includes(q))
        .slice(0, 12)
    }

    private renderDropdown(items: DistrictOption[]) {
      this.dropdown.replaceChildren()
      if (!items.length) {
        this.dropdown.classList.add('hidden')
        return
      }
      for (const opt of items) {
        const li = document.createElement('li')
        li.setAttribute('role', 'option')
        li.className =
          'flex cursor-pointer items-baseline justify-between gap-3 px-4 py-2.5 text-sm hover:bg-mist'
        const name = document.createElement('span')
        name.className = 'font-semibold text-ink'
        name.textContent = opt.d
        const canton = document.createElement('span')
        canton.className = 'font-mono text-[10px] uppercase tracking-[0.5px] text-ink-3'
        canton.textContent = opt.c
        li.append(name, canton)
        li.addEventListener('mousedown', (event) => {
          event.preventDefault()
          this.textInput.value = `${opt.d}, ${opt.c}`
          this.idInput.value = opt.di
          this.dropdown.classList.add('hidden')
          this.textInput.classList.add('border-canopy')
          this.textInput.classList.remove('border-rule')
        })
        this.dropdown.appendChild(li)
      }
      this.dropdown.classList.remove('hidden')
    }
  }

  if (!customElements.get('district-autocomplete')) {
    customElements.define('district-autocomplete', DistrictAutocomplete)
  }
</script>

---
import { actions } from 'astro:actions'
import { t } from '@lib/i18n'
import type { Category } from '@lib/queries/categories'
import type { CantonWithDistricts } from '@lib/queries/geography'
import type { PaymentMethod } from '@lib/queries/paymentMethods'
import Button from '@components/ui/Button.astro'
import Checkbox from '@components/ui/Checkbox.astro'
import ChipSelect from '@components/ui/ChipSelect.astro'
import Input from '@components/ui/Input.astro'
import Textarea from '@components/ui/Textarea.astro'

interface Props {
  cantons: CantonWithDistricts[]
  categories: Category[]
  paymentMethods: PaymentMethod[]
  inputErrors?: Record<string, string[] | undefined>
}

const { cantons, categories, paymentMethods, inputErrors = {} } = Astro.props
const errorFor = (name: string) => inputErrors[name]?.join(', ')

const categoryOptions = categories.map((c) => ({
  value: c.id,
  label: `${c.icon_emoji ?? ''} ${c.name}`.trim(),
}))

const paymentOptions = paymentMethods.map((pm) => ({
  value: pm.slug,
  label: pm.name,
}))

const cantonData = cantons.map((canton) => ({
  id: canton.id,
  name: canton.name,
  districts: canton.districts.map((d) => ({ id: d.id, name: d.name })),
}))
---

<form class="civic-card grid gap-5 p-5" method="POST" action={actions.registerProvider}>
  <div>
    <p class="civic-meta">{t('form.applicationMeta')}</p>
    <h2 class="mt-2 text-xl font-semibold text-ink">
      {t('form.applicationTitle')}
    </h2>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <Input label={t('form.businessName')} name="businessName" required minlength="3" maxlength="120" error={errorFor('businessName')} />
    <Input label={t('form.contactPerson')} name="contactName" required minlength="3" maxlength="120" error={errorFor('contactName')} />
    <Input label={t('form.phone')} name="phone" required type="tel" placeholder="8888-8888" error={errorFor('phone')} />
    <Input
      label={`WhatsApp`}
      name="whatsapp"
      type="tel"
      placeholder="+506 8888-8888"
      hint={t('common.optional')}
      error={errorFor('whatsapp')}
      class="md:col-span-2"
    />
  </div>

  <div class="grid gap-4">

    <service-area-picker class="grid gap-3" data-cantons={JSON.stringify(cantonData)}>
      <label class="text-sm font-semibold text-ink">
        {t('form.serviceArea')} <span class="text-clay">*</span>
      </label>

      <!-- Mode selector -->
      <div class="grid gap-2 rounded-civic border border-rule bg-surface-alt p-3">
        <label class="flex cursor-pointer items-center gap-2 text-sm text-ink">
          <input class="accent-ink" type="radio" name="sap-mode" value="country" data-sap-mode />
          <span>Todo Costa Rica</span>
        </label>
        <label class="flex cursor-pointer items-center gap-2 text-sm text-ink">
          <input class="accent-ink" type="radio" name="sap-mode" value="canton" data-sap-mode />
          <span>Por cantón(es) completo(s)</span>
        </label>
        <label class="flex cursor-pointer items-center gap-2 text-sm text-ink">
          <input class="accent-ink" type="radio" name="sap-mode" value="district" data-sap-mode checked />
          <span>Por distrito(s) específico(s)</span>
        </label>
      </div>

      <!-- Canton picker (hidden until mode=canton) -->
      <div data-sap-canton-section class="hidden">
        <div class="grid gap-2">
        <div class="relative">
          <input
            type="text"
            autocomplete="off"
            placeholder="Buscar cantón…"
            class="w-full rounded-civic border border-rule bg-surface px-3 py-2.5 text-sm outline-none placeholder:text-ink-3 focus:border-ink"
            data-sap-canton-text
            aria-autocomplete="list"
            aria-haspopup="listbox"
          />
          <ul
            class="absolute left-0 right-0 top-full z-50 mt-1 hidden max-h-56 overflow-y-auto rounded-civic border border-rule bg-surface shadow-civic-lg"
            data-sap-canton-dropdown
            role="listbox"
          ></ul>
        </div>
        <div class="flex flex-wrap gap-2" data-sap-canton-chips></div>
        </div>
      </div>

      <!-- District picker (shown by default for mode=district) -->
      <div data-sap-district-section>
        <div class="grid gap-2">
        <div class="relative">
          <input
            type="text"
            autocomplete="off"
            placeholder="Buscar distrito o cantón…"
            class="w-full rounded-civic border border-rule bg-surface px-3 py-2.5 text-sm outline-none placeholder:text-ink-3 focus:border-ink"
            data-sap-district-text
            aria-autocomplete="list"
            aria-haspopup="listbox"
          />
          <ul
            class="absolute left-0 right-0 top-full z-50 mt-1 hidden max-h-56 overflow-y-auto rounded-civic border border-rule bg-surface shadow-civic-lg"
            data-sap-district-dropdown
            role="listbox"
          ></ul>
        </div>
        <div class="flex flex-wrap gap-2" data-sap-district-chips></div>
        </div>
      </div>

      <!-- Serialized hidden field -->
      <input type="hidden" name="serviceAreaJson" data-sap-json />
      {errorFor('serviceAreaJson') && (
        <span class="text-xs font-medium text-clay">{errorFor('serviceAreaJson')}</span>
      )}
    </service-area-picker>

    <ChipSelect
      name="categoryIds"
      label={t('form.serviceCategories')}
      options={categoryOptions}
      max={4}
      required
      placeholder="Buscar categoría de servicio…"
      error={errorFor('categoryIds')}
    />

  <ChipSelect
    name="paymentMethodSlugs"
    label="Métodos de pago aceptados"
    options={paymentOptions}
    max={11}
    placeholder="Buscar método de pago…"
    error={errorFor('paymentMethodSlugs')}
  />
    <Textarea
      label={t('form.serviceDescription')}
      name="description"
      required
      minlength={30}
      maxlength={500}
      rows={5}
      error={errorFor('description')}
    />
  </div>
  <div class="grid gap-4 rounded-civic border border-rule bg-surface-alt p-4 md:grid-cols-2">
    <Input label={t('form.yearsActive')} name="yearsActive" type="number" value="1" />
    <Checkbox name="worksWeekends" value="true" label={t('form.worksWeekends')} variant="plain" class="self-end pb-2" />
  </div>

  <input name="sourceLocale" type="hidden" value="es" />
  <label class="hidden">
    Website
    <input name="website" tabindex="-1" autocomplete="off" />
  </label>

  <Button variant="primary" type="submit" full>
    {t('form.submit')}
  </Button>
</form>

<script>
  type CantonData = { id: string; name: string; districts: { id: string; name: string }[] }

  type ServiceArea =
    | { level: 'country' }
    | { level: 'canton'; canton_id: string; label: string }
    | { level: 'district'; district_id: string; label: string }

  function normalizeText(value: string): string {
    return value
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .replace(/[ñÑ]/g, 'n')
      .toLowerCase()
  }

  class ServiceAreaPicker extends HTMLElement {
    private cantons: CantonData[] = []
    private selected: ServiceArea[] = []
    private mode: 'country' | 'canton' | 'district' = 'district'

    // DOM refs
    private jsonInput!: HTMLInputElement
    private cantonSection!: HTMLElement
    private districtSection!: HTMLElement
    private cantonText!: HTMLInputElement
    private cantonDropdown!: HTMLUListElement
    private cantonChips!: HTMLElement
    private districtText!: HTMLInputElement
    private districtDropdown!: HTMLUListElement
    private districtChips!: HTMLElement

    connectedCallback() {
      this.jsonInput = this.querySelector<HTMLInputElement>('[data-sap-json]')!
      this.cantonSection = this.querySelector<HTMLElement>('[data-sap-canton-section]')!
      this.districtSection = this.querySelector<HTMLElement>('[data-sap-district-section]')!
      this.cantonText = this.querySelector<HTMLInputElement>('[data-sap-canton-text]')!
      this.cantonDropdown = this.querySelector<HTMLUListElement>('[data-sap-canton-dropdown]')!
      this.cantonChips = this.querySelector<HTMLElement>('[data-sap-canton-chips]')!
      this.districtText = this.querySelector<HTMLInputElement>('[data-sap-district-text]')!
      this.districtDropdown = this.querySelector<HTMLUListElement>('[data-sap-district-dropdown]')!
      this.districtChips = this.querySelector<HTMLElement>('[data-sap-district-chips]')!

      try {
        this.cantons = JSON.parse(this.dataset.cantons ?? '[]')
      } catch {
        this.cantons = []
      }

      // Mode radio buttons
      this.querySelectorAll<HTMLInputElement>('[data-sap-mode]').forEach((radio) => {
        radio.addEventListener('change', () => {
          this.mode = radio.value as typeof this.mode
          this.selected = []
          this.renderAllChips()
          this.updateSections()
          this.serialize()
        })
      })

      // Canton autocomplete
      this.cantonText.addEventListener('input', () => this.renderCantonDropdown())
      this.cantonText.addEventListener('focus', () => this.renderCantonDropdown())
      this.cantonText.addEventListener('blur', () =>
        window.setTimeout(() => this.cantonDropdown.classList.add('hidden'), 150),
      )

      // District autocomplete
      this.districtText.addEventListener('input', () => this.renderDistrictDropdown())
      this.districtText.addEventListener('focus', () => this.renderDistrictDropdown())
      this.districtText.addEventListener('blur', () =>
        window.setTimeout(() => this.districtDropdown.classList.add('hidden'), 150),
      )

      // Initial serialization (country mode serializes immediately)
      this.serialize()
    }

    // ── Sections ──────────────────────────────────────────────────

    private updateSections() {
      if (this.mode === 'country') {
        this.cantonSection.classList.add('hidden')
        this.districtSection.classList.add('hidden')
      } else if (this.mode === 'canton') {
        this.cantonSection.classList.remove('hidden')
        this.districtSection.classList.add('hidden')
      } else {
        this.cantonSection.classList.add('hidden')
        this.districtSection.classList.remove('hidden')
      }
    }

    // ── Canton autocomplete ────────────────────────────────────────

    private renderCantonDropdown() {
      const q = normalizeText(this.cantonText.value)
      const selectedIds = new Set(
        this.selected
          .filter((s): s is { level: 'canton'; canton_id: string; label: string } => s.level === 'canton')
          .map((s) => s.canton_id),
      )
      const matches = this.cantons
        .filter((c) => !selectedIds.has(c.id) && (!q || normalizeText(c.name).includes(q)))
        .slice(0, 10)

      this.cantonDropdown.replaceChildren()
      if (!matches.length) {
        this.cantonDropdown.classList.add('hidden')
        return
      }
      for (const canton of matches) {
        const li = document.createElement('li')
        li.setAttribute('role', 'option')
        li.className = 'cursor-pointer px-4 py-2.5 text-sm font-semibold text-ink hover:bg-mist'
        li.textContent = canton.name
        li.addEventListener('mousedown', (e) => {
          e.preventDefault()
          this.selected.push({ level: 'canton', canton_id: canton.id, label: canton.name })
          this.cantonText.value = ''
          this.cantonDropdown.classList.add('hidden')
          this.renderAllChips()
          this.serialize()
        })
        this.cantonDropdown.appendChild(li)
      }
      this.cantonDropdown.classList.remove('hidden')
    }

    // ── District autocomplete ──────────────────────────────────────

    private renderDistrictDropdown() {
      const q = normalizeText(this.districtText.value)
      if (!q) {
        this.districtDropdown.classList.add('hidden')
        return
      }
      const selectedIds = new Set(
        this.selected
          .filter(
            (s): s is { level: 'district'; district_id: string; label: string } => s.level === 'district',
          )
          .map((s) => s.district_id),
      )
      const matches: Array<{ districtId: string; districtName: string; cantonName: string }> = []
      for (const canton of this.cantons) {
        for (const district of canton.districts) {
          if (
            !selectedIds.has(district.id) &&
            (normalizeText(district.name).includes(q) || normalizeText(canton.name).includes(q))
          ) {
            matches.push({ districtId: district.id, districtName: district.name, cantonName: canton.name })
          }
        }
        if (matches.length >= 12) break
      }

      this.districtDropdown.replaceChildren()
      if (!matches.length) {
        this.districtDropdown.classList.add('hidden')
        return
      }
      for (const match of matches) {
        const li = document.createElement('li')
        li.setAttribute('role', 'option')
        li.className =
          'flex cursor-pointer items-baseline justify-between gap-3 px-4 py-2.5 text-sm hover:bg-mist'
        const name = document.createElement('span')
        name.className = 'font-semibold text-ink'
        name.textContent = match.districtName
        const canton = document.createElement('span')
        canton.className = 'font-mono text-[10px] uppercase tracking-[0.5px] text-ink-3'
        canton.textContent = match.cantonName
        li.append(name, canton)
        li.addEventListener('mousedown', (e) => {
          e.preventDefault()
          this.selected.push({
            level: 'district',
            district_id: match.districtId,
            label: `${match.districtName}, ${match.cantonName}`,
          })
          this.districtText.value = ''
          this.districtDropdown.classList.add('hidden')
          this.renderAllChips()
          this.serialize()
        })
        this.districtDropdown.appendChild(li)
      }
      this.districtDropdown.classList.remove('hidden')
    }

    // ── Chips ──────────────────────────────────────────────────────

    private renderAllChips() {
      this.cantonChips.replaceChildren()
      this.districtChips.replaceChildren()

      for (const area of this.selected) {
        if (area.level === 'canton') {
          this.cantonChips.appendChild(this.buildChip(area.label, () => this.removeArea(area)))
        } else if (area.level === 'district') {
          this.districtChips.appendChild(this.buildChip(area.label, () => this.removeArea(area)))
        }
      }
    }

    private buildChip(label: string, onRemove: () => void): HTMLElement {
      const chip = document.createElement('span')
      chip.className =
        'inline-flex items-center gap-1.5 rounded-full bg-ink px-3 py-1 text-xs font-semibold text-surface'
      const text = document.createElement('span')
      text.textContent = label
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'text-surface/70 hover:text-surface leading-none'
      btn.setAttribute('aria-label', `Eliminar ${label}`)
      btn.textContent = '×'
      btn.addEventListener('click', onRemove)
      chip.append(text, btn)
      return chip
    }

    private removeArea(target: ServiceArea) {
      if (target.level === 'country') {
        this.selected = []
      } else if (target.level === 'canton') {
        this.selected = this.selected.filter(
          (a) => !(a.level === 'canton' && a.canton_id === target.canton_id),
        )
      } else {
        this.selected = this.selected.filter(
          (a) => !(a.level === 'district' && a.district_id === target.district_id),
        )
      }
      this.renderAllChips()
      this.serialize()
    }

    // ── Serialize ─────────────────────────────────────────────────

    private serialize() {
      if (this.mode === 'country') {
        this.jsonInput.value = JSON.stringify([{ level: 'country' }])
        return
      }
      // Strip display-only 'label' field before serializing
      const payload = this.selected.map((area) => {
        if (area.level === 'canton') return { level: 'canton', canton_id: area.canton_id }
        if (area.level === 'district') return { level: 'district', district_id: area.district_id }
        return { level: 'country' }
      })
      this.jsonInput.value = JSON.stringify(payload)
    }
  }

  if (!customElements.get('service-area-picker')) {
    customElements.define('service-area-picker', ServiceAreaPicker)
  }
</script>

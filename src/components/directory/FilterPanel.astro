---
import Icon from '@components/ui/Icon.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'

interface FilterOption {
  key: string
  es: string
  en: string
  active?: boolean
  href: string
}

interface SortOption {
  value: string
  es: string
  en: string
  active?: boolean
  href: string
}

interface Props {
  filters: FilterOption[]
  sortOptions: SortOption[]
}

const { filters, sortOptions } = Astro.props
---

<aside class="hidden md:block">
  <div class="flex items-center gap-2 border-b border-rule pb-2">
    <Icon name="filter" size={14} class="text-ink-3" />
    <span class="civic-meta"><TranslatedText es="Filtros" en="Filters" /></span>
  </div>
  <div class="mt-3 grid gap-2 text-sm text-ink-2">
    {
      filters.map((filter) => (
        <a
          class:list={[
            'flex items-center gap-2 rounded-civic border px-3 py-2 no-underline',
            filter.active
              ? 'border-canopy bg-canopy-soft font-semibold text-canopy'
              : 'border-rule bg-surface text-ink-2 hover:border-canopy hover:text-canopy',
          ]}
          href={filter.href}
        >
          <span class="flex h-4 w-4 items-center justify-center rounded-civic border border-current text-[10px]">
            {filter.active ? '✓' : ''}
          </span>
          <TranslatedText es={filter.es} en={filter.en} />
        </a>
      ))
    }
  </div>
  <div class="mt-6 rounded-civic border border-rule bg-surface-alt p-4">
    <p class="civic-meta">
      <TranslatedText es="Ordenar" en="Sort" />
    </p>
    <div class="mt-3 grid gap-2">
      {
        sortOptions.map((option) => (
          <a
            class:list={[
              'text-sm no-underline',
              option.active ? 'font-semibold text-canopy' : 'text-ink-2 hover:text-canopy',
            ]}
            href={option.href}
          >
            <TranslatedText es={option.es} en={option.en} />
          </a>
        ))
      }
    </div>
  </div>
</aside>

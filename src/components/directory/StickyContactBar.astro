---
import Icon from '@components/ui/Icon.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'

interface Props {
  phone: string
  whatsapp?: string | null
}

const { phone, whatsapp } = Astro.props
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : null
---

<div class="fixed inset-x-0 bottom-0 z-40 flex gap-2 border-t border-rule bg-surface p-3 shadow-[0_-2px_12px_rgba(0,0,0,0.06)] md:hidden">
  {
    whatsappUrl && (
      <a class="civic-button flex-[2] gap-2 bg-whatsapp py-3 text-white" href={whatsappUrl}>
        <Icon name="wa" size={15} /><span>WhatsApp</span>
      </a>
    )
  }
  <a class="civic-button flex-1 gap-2 border-2 border-ink bg-surface py-3 text-ink" href={`tel:${phone}`}>
    <Icon name="phone" size={14} /><span><TranslatedText es="Llamar" en="Call" /></span>
  </a>
</div>

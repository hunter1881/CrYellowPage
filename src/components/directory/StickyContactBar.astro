---
import Button from '@components/ui/Button.astro'
import Icon from '@components/ui/Icon.astro'
import { t } from '@lib/i18n'

interface Props {
  phone: string
  whatsapp?: string | null
}

const { phone, whatsapp } = Astro.props
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : null
---

<div class="fixed inset-x-0 bottom-0 z-40 flex gap-2 border-t border-rule bg-surface p-3 shadow-[0_-2px_12px_rgba(0,0,0,0.06)] md:hidden">
  {whatsappUrl && (
    <Button variant="whatsapp" href={whatsappUrl} class="flex-[2] gap-2 py-3">
      <Icon name="wa" size={15} /><span>WhatsApp</span>
    </Button>
  )}
  <Button variant="outline" href={`tel:${phone}`} class="flex-1 gap-2 py-3">
    <Icon name="phone" size={14} /><span>{t('sticky.call')}</span>
  </Button>
</div>

---
import { actions } from 'astro:actions'
import Icon from '@components/ui/Icon.astro'
import { t } from '@lib/i18n'

interface Props {
  providerId: string
  providerName: string
}

const { providerId, providerName } = Astro.props

const result = Astro.getActionResult(actions.submitReview)
const submitted = result?.data?.providerId === providerId && !result?.error
const formError = result?.error?.message ?? null
---

<section class="civic-card mt-4 p-5" id="escribir-resena" aria-label={`Escribir reseña para ${providerName}`}>
  <p class="civic-meta mb-3">{t('reviews.writeReview')}</p>

  {submitted ? (
    <div class="flex items-center gap-3 rounded-civic border border-canopy/30 bg-canopy-soft px-4 py-3 text-sm font-semibold text-canopy">
      <Icon name="check" size={16} />
      {t('reviews.submitSuccess')}
    </div>
  ) : (
    <form
      method="POST"
      action={actions.submitReview}
      x-data="{ submitting: false }"
      data-review-form
    >
      <input type="hidden" name="providerId" value={providerId} />

      {formError && (
        <p class="mb-4 rounded-civic border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700" role="alert">
          {formError}
        </p>
      )}

      {/* Star rating */}
      <div class="mb-4">
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.5px] text-ink-3">
          {t('reviews.rating')}<span class="ml-0.5 text-clay">*</span>
        </label>
        <star-rating>
          <div class="flex gap-1" role="radiogroup" aria-label={t('reviews.rating')} data-stars-container>
            {[1, 2, 3, 4, 5].map((n) => (
              <button
                type="button"
                data-value={n}
                aria-label={`${n} estrella${n > 1 ? 's' : ''}`}
                class="star-btn text-2xl text-ink-3/30 transition-colors hover:text-star focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-canopy"
              >
                ★
              </button>
            ))}
          </div>
          <input type="hidden" name="rating" value="" />
          <p class="sr-only" aria-live="polite" data-star-label></p>
        </star-rating>
        <p class="mt-1 text-xs text-red-600 hidden" data-rating-error>{t('reviews.errorRequired')}</p>
      </div>

      {/* Author name — required */}
      <div class="mb-4">
        <label for="review-author" class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.5px] text-ink-3">
          {t('reviews.yourName')}<span class="ml-0.5 text-clay">*</span>
        </label>
        <input
          id="review-author"
          type="text"
          name="authorName"
          maxlength="80"
          placeholder={t('reviews.namePlaceholder')}
          autocomplete="name"
          class="w-full rounded-civic border border-rule bg-surface px-3 py-2 text-sm text-ink placeholder:text-ink-3/50 focus:border-canopy focus:outline-none focus:ring-1 focus:ring-canopy"
        />
        <p class="mt-1 text-xs text-red-600 hidden" data-name-error>{t('reviews.errorName')}</p>
      </div>

      {/* Comment — required */}
      <div class="mb-4">
        <label for="review-comment" class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.5px] text-ink-3">
          {t('reviews.yourComment')}<span class="ml-0.5 text-clay">*</span>
        </label>
        <textarea
          id="review-comment"
          name="comment"
          rows="3"
          maxlength="800"
          placeholder={t('reviews.commentPlaceholder')}
          class="w-full resize-none rounded-civic border border-rule bg-surface px-3 py-2 text-sm text-ink placeholder:text-ink-3/50 focus:border-canopy focus:outline-none focus:ring-1 focus:ring-canopy"
        ></textarea>
        <p class="mt-1 text-xs text-red-600 hidden" data-comment-error>{t('reviews.errorComment')}</p>
      </div>

      {/* Work confirmed — required Yes / No */}
      <div class="mb-5">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.5px] text-ink-3">
          {t('reviews.workConfirmedQuestion')}<span class="ml-0.5 text-clay">*</span>
        </p>
        <div class="flex gap-3">
          <label data-wc-label class="flex flex-1 cursor-pointer items-center gap-2.5 rounded-civic border border-rule bg-surface-alt p-3 has-[:checked]:border-canopy/40 has-[:checked]:bg-canopy-soft">
            <input type="radio" name="workConfirmed" value="yes" class="accent-canopy" />
            <span class="text-sm font-semibold text-ink">{t('reviews.workConfirmedYes')}</span>
          </label>
          <label data-wc-label class="flex flex-1 cursor-pointer items-center gap-2.5 rounded-civic border border-rule bg-surface-alt p-3 has-[:checked]:border-canopy/40 has-[:checked]:bg-canopy-soft">
            <input type="radio" name="workConfirmed" value="no" class="accent-canopy" />
            <span class="text-sm font-semibold text-ink">{t('reviews.workConfirmedNo')}</span>
          </label>
        </div>
        <p class="mt-1 text-xs text-red-600 hidden" data-work-error>{t('reviews.errorWorkConfirmed')}</p>
      </div>

      <button
        type="button"
        x-bind:disabled="submitting"
        x-on:click="
          const form = $el.closest('form');
          let ok = true;
          const ri = form.querySelector('[name=rating]'), re = form.querySelector('[data-rating-error]'), sc = form.querySelector('[data-stars-container]');
          if (!ri.value) { re.classList.remove('hidden'); sc.classList.add('border','border-clay','rounded-civic'); ok = false; } else { re.classList.add('hidden'); sc.classList.remove('border','border-clay','rounded-civic'); }
          const ni = form.querySelector('[name=authorName]'), ne = form.querySelector('[data-name-error]');
          if (!ni.value.trim()) { ne.classList.remove('hidden'); ni.classList.add('border-clay'); ni.classList.remove('border-rule'); ok = false; } else { ne.classList.add('hidden'); ni.classList.remove('border-clay'); ni.classList.add('border-rule'); }
          const ci = form.querySelector('[name=comment]'), ce = form.querySelector('[data-comment-error]');
          if (!ci.value.trim()) { ce.classList.remove('hidden'); ci.classList.add('border-clay'); ci.classList.remove('border-rule'); ok = false; } else { ce.classList.add('hidden'); ci.classList.remove('border-clay'); ci.classList.add('border-rule'); }
          const wc = form.querySelector('[name=workConfirmed]:checked'), we = form.querySelector('[data-work-error]');
          const wls = form.querySelectorAll('[data-wc-label]');
          if (!wc) { we.classList.remove('hidden'); wls.forEach(l=>{l.classList.add('border-clay');l.classList.remove('border-rule');}); ok = false; } else { we.classList.add('hidden'); wls.forEach(l=>{l.classList.remove('border-clay');l.classList.add('border-rule');}); }
          if (!ok) return;
          submitting = true;
          form.requestSubmit();
        "
        class="w-full rounded-civic bg-canopy px-4 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
      >
        <span x-show="!submitting">{t('reviews.submit')}</span>
        <span x-show="submitting" x-cloak>Publicando…</span>
      </button>
    </form>
  )}
</section>

<script>
  class StarRating extends HTMLElement {
    connectedCallback() {
      const hiddenInput = this.querySelector<HTMLInputElement>('input[type="hidden"]')
      const label = this.querySelector<HTMLElement>('[data-star-label]')
      const buttons = Array.from(this.querySelectorAll<HTMLButtonElement>('.star-btn'))

      if (!hiddenInput) return

      const highlight = (value: number) => {
        buttons.forEach((btn, i) => {
          const active = i < value
          btn.classList.toggle('text-star', active)
          btn.classList.toggle('text-ink-3/30', !active)
        })
      }

      const setValue = (value: number) => {
        hiddenInput.value = String(value)
        if (label) label.textContent = `${value} estrella${value > 1 ? 's' : ''} seleccionada${value > 1 ? 's' : ''}`
        const form = this.closest('form')
        form?.querySelector('[data-rating-error]')?.classList.add('hidden')
        const sc = form?.querySelector('[data-stars-container]')
        sc?.classList.remove('border', 'border-clay', 'rounded-civic')
        highlight(value)
      }

      buttons.forEach((btn, i) => {
        btn.addEventListener('mouseenter', () => highlight(i + 1))
        btn.addEventListener('mouseleave', () => highlight(hiddenInput.value ? Number(hiddenInput.value) : 0))
        btn.addEventListener('click', () => setValue(i + 1))
      })
    }
  }

  if (!customElements.get('star-rating')) customElements.define('star-rating', StarRating)

  // Live-clear errors as the user fixes each field
  function attachReviewFormListeners() {
    document.querySelectorAll<HTMLFormElement>('[data-review-form]').forEach((form) => {
      const nameInput = form.querySelector<HTMLInputElement>('[name=authorName]')
      const nameError = form.querySelector<HTMLElement>('[data-name-error]')
      nameInput?.addEventListener('input', () => {
        if (nameInput.value.trim()) {
          nameError?.classList.add('hidden')
          nameInput.classList.remove('border-clay')
          nameInput.classList.add('border-rule')
        }
      })

      const commentInput = form.querySelector<HTMLTextAreaElement>('[name=comment]')
      const commentError = form.querySelector<HTMLElement>('[data-comment-error]')
      commentInput?.addEventListener('input', () => {
        if (commentInput.value.trim()) {
          commentError?.classList.add('hidden')
          commentInput.classList.remove('border-clay')
          commentInput.classList.add('border-rule')
        }
      })

      form.querySelectorAll<HTMLInputElement>('[name=workConfirmed]').forEach((radio) => {
        radio.addEventListener('change', () => {
          form.querySelector('[data-work-error]')?.classList.add('hidden')
          form.querySelectorAll<HTMLElement>('[data-wc-label]').forEach((l) => {
            l.classList.remove('border-clay')
            l.classList.add('border-rule')
          })
        })
      })
    })
  }

  // Run immediately on initial load (module scripts execute after DOM is ready)
  attachReviewFormListeners()
  // Re-run after view transition navigations
  document.addEventListener('astro:page-load', attachReviewFormListeners)
</script>

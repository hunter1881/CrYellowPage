---
import { t } from '@lib/i18n'
import type { Category } from '@lib/queries/categories'

interface Props {
  categories: (Category & { count?: number })[]
  basePath: string
}

const { categories, basePath } = Astro.props
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
  {
    categories.map((category) => (
      <a
        class="civic-card civic-card-hover flex items-center gap-3 p-4 text-ink no-underline"
        href={`${basePath}/${category.slug}`}
      >
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-civic bg-canopy-soft text-xl" aria-hidden="true">
          {category.icon_emoji ?? '#'}
        </span>
        <span class="min-w-0">
          <span class="block text-[15px] font-semibold tracking-[-0.1px]">{category.name}</span>
          {category.count != null ? (
            <span class="civic-meta mt-1 block">
              {category.count} {t('common.providers')}
            </span>
          ) : (
            <span class="civic-meta mt-1 block">{t('category.viewProviders')}</span>
          )}
        </span>
      </a>
    ))
  }
</div>

---
import Button from '@components/ui/Button.astro'
import { t } from '@lib/i18n'

interface Props {
  titleEs?: string
  bodyEs?: string
  actionHref?: string
}

const {
  titleEs = t('empty.defaultTitle'),
  bodyEs = t('empty.defaultBody'),
  actionHref = '/#provider-signup',
} = Astro.props
---

<section class="rounded-civic border border-rule bg-surface-alt p-6 text-center">
  <p class="civic-meta">
    {t('empty.label')}
  </p>
  <h2 class="mt-3 text-xl font-semibold tracking-[-0.3px] text-ink">
    {titleEs}
  </h2>
  <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-ink-2">
    {bodyEs}
  </p>
  <Button variant="primary" href={actionHref} class="mt-5">
    {t('empty.registerCta')}
  </Button>
</section>

---
import Icon from '@components/ui/Icon.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'
import type { Category } from '@lib/queries/categories'
import type { CantonWithDistricts } from '@lib/queries/geography'

interface Props {
  cantons?: CantonWithDistricts[]
  categories?: Category[]
  publishedListings?: string[]
}

const { categories = [], publishedListings = [] } = Astro.props
const categoryLookup = categories.map((category) => ({
  name: category.name,
  slug: category.slug,
}))
---

<!-- Mobile: stacked layout -->
<div class="md:hidden">
  <button
    type="button"
    class="flex w-full items-center gap-3 rounded-civic border-2 border-ink bg-surface px-4 py-3 text-left"
    data-open-search-location
    aria-label="Seleccionar ubicación"
  >
    <Icon name="pin" size={16} class="shrink-0 text-canopy" />
    <span class="min-w-0 flex-1">
      <span class="block font-mono text-[10px] uppercase tracking-[0.5px] text-ink-3">
        <TranslatedText es="Ubicación" en="Location" />
      </span>
      <span class="block text-sm font-semibold text-ink" data-search-location-label
        data-label-es="Seleccionar distrito" data-label-en="Select district">
        Seleccionar distrito
      </span>
    </span>
    <Icon name="chevronDown" size={14} class="shrink-0 text-ink-3" />
  </button>
  <form class="mt-2 flex overflow-hidden rounded-civic border-2 border-ink bg-surface" action="/buscar" method="get" data-directory-search>
    <input type="hidden" name="district" data-search-district-input />
    <input type="hidden" name="districtId" data-search-district-id-input />
    <input
      class="min-w-0 flex-1 border-none bg-transparent px-4 py-3 text-sm font-semibold text-ink outline-none placeholder:text-ink-3"
      type="search"
      name="q"
      placeholder="¿Qué necesitás? Ej: fontanero"
      data-placeholder-es="¿Qué necesitás? Ej: fontanero"
      data-placeholder-en="What do you need? e.g. plumber"
    />
    <button class="flex items-center bg-canopy px-4 text-white hover:bg-canopy-ink" type="submit" aria-label="Buscar">
      <Icon name="arrow" size={18} />
    </button>
  </form>
</div>

<!-- Desktop: 3-column grid -->
<form
  class="hidden overflow-hidden rounded-civic border-2 border-ink bg-surface md:grid md:grid-cols-[1.4fr_1.1fr_auto]"
  action="/buscar"
  method="get"
  data-directory-search
>
  <label class="grid gap-1 border-r border-rule p-3">
    <span class="civic-meta"><TranslatedText es="Buscar" en="Search" /></span>
    <input
      class="min-w-0 border-none bg-transparent text-sm font-semibold text-ink outline-none placeholder:text-ink-3"
      type="search"
      name="q"
      placeholder="¿Qué necesitás? Ej: fontanero"
      data-placeholder-es="¿Qué necesitás? Ej: fontanero"
      data-placeholder-en="What do you need? e.g. plumber"
    />
  </label>
  <button
    type="button"
    class="grid gap-1 border-r border-rule p-3 text-left hover:bg-mist"
    data-open-search-location
  >
    <span class="civic-meta"><TranslatedText es="Ubicación" en="Location" /></span>
    <span class="flex items-center gap-2 text-sm font-semibold text-ink">
      <span data-search-location-label
        data-label-es="Seleccionar distrito" data-label-en="Select district">
        Seleccionar distrito
      </span>
      <Icon name="chevronDown" size={12} class="ml-auto text-ink-3" />
    </span>
  </button>
  <input type="hidden" name="district" data-search-district-input />
  <input type="hidden" name="districtId" data-search-district-id-input />
  <button class="bg-canopy px-6 text-sm font-semibold text-white hover:bg-canopy-ink" type="submit">
    <TranslatedText es="Encontrar" en="Find" />
  </button>
</form>

<script is:inline type="application/json" data-published-listings set:html={JSON.stringify(publishedListings)} />

<script is:inline define:vars={{ categoryLookup }}>
  function normalizeSearchValue(value) {
    return value
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .replace(/[ñÑ]/g, 'n')
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
  }

  const categoryAliases = {
    plomero: 'fontaneria',
    plomeria: 'fontaneria',
    fontanero: 'fontaneria',
    fuga: 'fontaneria',
    fugas: 'fontaneria',
    electrico: 'electricidad',
    electricista: 'electricidad',
    jardinero: 'jardineria',
    jardin: 'jardineria',
    limpieza: 'limpieza',
    limpiar: 'limpieza',
    reparacion: 'reparaciones',
    reparaciones: 'reparaciones',
    cerrajero: 'cerrajeria',
    pintura: 'pintura',
    pintor: 'pintura',
    aire: 'aire-acondicionado',
    'aire-acondicionado': 'aire-acondicionado',
  }

  const categoriesBySearchTerm = new Map()
  const publishedListingSet = new Set(
    JSON.parse(document.querySelector('[data-published-listings]')?.textContent ?? '[]'),
  )
  categoryLookup.forEach((category) => {
    categoriesBySearchTerm.set(category.slug, category.slug)
    categoriesBySearchTerm.set(normalizeSearchValue(category.name), category.slug)
  })
  Object.entries(categoryAliases).forEach(([alias, slug]) => {
    categoriesBySearchTerm.set(alias, slug)
  })

  document.querySelectorAll('[data-directory-search]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      const formData = new FormData(form)
      const districtPath = String(formData.get('district') ?? '').replace(/^\/+|\/+$/g, '')
      const districtId = String(formData.get('districtId') ?? '').trim()
      const query = normalizeSearchValue(String(formData.get('q') ?? ''))
      const categorySlug = categoriesBySearchTerm.get(query)

      // Has district + category match → go to category listing
      if (districtPath && categorySlug) {
        const listingPath = `${districtPath}/${categorySlug}`
        if (publishedListingSet.has(listingPath)) {
          event.preventDefault()
          window.location.assign(`/${listingPath}/`)
          return
        }
      }

      // Has district but no category match → go to district page
      if (districtPath && !categorySlug) {
        event.preventDefault()
        window.location.assign(`/${districtPath}/`)
        return
      }

      // No district → go to /buscar with query (and districtId if somehow set)
      event.preventDefault()
      const rawQuery = String(formData.get('q') ?? '').trim()
      if (!rawQuery) return
      const params = new URLSearchParams({ q: rawQuery })
      if (districtId) params.set('district', districtId)
      window.location.assign(`/buscar?${params.toString()}`)
    })
  })
</script>

---
import Icon from '@components/ui/Icon.astro'
import { t } from '@lib/i18n'
---

<div
  class="fixed inset-0 z-[100] hidden bg-ink/50"
  data-mobile-drawer
  aria-hidden="true"
>
  <aside class="ml-auto flex h-full w-[min(86vw,340px)] flex-col bg-surface p-5 shadow-xl">
    <div class="mb-4 flex items-center justify-between">
      <p class="text-sm font-semibold text-ink">{t('mobile.menu')}</p>
      <button class="flex h-8 w-8 items-center justify-center rounded-civic border border-rule text-ink-2 hover:text-ink" type="button" data-close-mobile-menu aria-label="Cerrar menu">
        <Icon name="close" size={16} />
      </button>
    </div>

    <nav class="grid text-base font-medium" aria-label="Mobile primary">
      <a class="border-b border-rule-soft py-4 text-ink no-underline" href="/">{t('mobile.home')}</a>
      <a class="border-b border-rule-soft py-4 text-ink no-underline" href="/#cantones">{t('nav.cantons')}</a>
      <a class="border-b border-rule-soft py-4 text-ink no-underline" href="/#categories">{t('nav.categories')}</a>
      <a class="border-b border-rule-soft py-4 text-ink no-underline" href="/register-provider/">{t('nav.provider')}</a>
      <button class="border-b border-rule-soft py-4 text-left text-ink" type="button" data-open-location>
        {t('nav.changeLocation')}
      </button>
    </nav>
  </aside>
</div>

---
import { Image } from 'astro:assets'
import Button from '@components/ui/Button.astro'
import Card from '@components/ui/Card.astro'
import Icon from '@components/ui/Icon.astro'
import Badge from '@components/ui/Badge.astro'
import { t } from '@lib/i18n'
import { providerDisplayMeta } from '@lib/providerPresentation'
import type { ReviewSummary } from '@lib/queries/reviews'
import type { ProviderListItem } from '@lib/queries/providers'
import { providerUrl } from '@lib/slug'

interface Props {
  provider: ProviderListItem
  reviewSummary?: ReviewSummary
  fromPath?: string
}

const { provider, reviewSummary, fromPath } = Astro.props
const displayMeta = providerDisplayMeta(provider, reviewSummary)
const providerHref = fromPath
  ? `${providerUrl(provider.id, provider.name)}?from=${encodeURIComponent(fromPath)}`
  : providerUrl(provider.id, provider.name)
---

<Card tag="article" hover class="grid gap-4 p-4 md:grid-cols-[1fr_auto]">
  <div class="flex gap-4">
    <div class="h-16 w-16 shrink-0 overflow-hidden rounded-civic border border-rule bg-surface">
      {
        provider.photo_url ? (
          <Image
            class="h-full w-full object-cover"
            src={provider.photo_url}
            alt={`Foto de ${provider.name}`}
            width={180}
            height={180}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-canopy-ink to-canopy text-[10px] font-semibold uppercase tracking-[0.5px] text-white/60">
            {t('provider.photo')}
          </div>
        )
      }
    </div>
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <h2 class="text-base font-semibold tracking-[-0.2px]">
          <a class="text-ink no-underline hover:text-canopy" href={providerHref}>
            {provider.name}
          </a>
        </h2>
        <Badge label={t('badge.verified')} />
      </div>
      <p class="mt-2 text-sm leading-6 text-ink/75">
        {provider.description ?? t('provider.defaultDescription')}
      </p>
      <div class="mt-2 flex flex-wrap gap-3 font-mono text-[11px] uppercase tracking-[0.5px] text-ink-3">
        {displayMeta.rating !== null && (
          <span class="flex items-center gap-1 text-star"><Icon name="star" size={11} /> {displayMeta.rating} <span class="text-ink-3">({displayMeta.reviewCount})</span></span>
        )}
        {displayMeta.yearsActive !== null && (
          <span>{displayMeta.yearsActive} {t('provider.yearsUnit')}</span>
        )}
        {displayMeta.completedJobs !== null && (
          <span>{displayMeta.completedJobs} {t('provider.jobsUnit')}</span>
        )}
      </div>
    </div>
  </div>
  <div class="flex flex-wrap gap-2 md:flex-col md:items-stretch md:justify-end">
    {provider.whatsapp && (
      <Button
        variant="whatsapp"
        href={`https://wa.me/${provider.whatsapp.replace(/\D/g, '')}`}
        class="gap-2"
      >
        <Icon name="wa" size={14} /><span>WhatsApp</span>
      </Button>
    )}
    <Button variant="outline" href={`tel:${provider.phone}`} class="gap-2">
      <Icon name="phone" size={14} /><span>{t('common.call')}</span>
    </Button>
  </div>
</Card>

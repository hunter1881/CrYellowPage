---
import { Image } from 'astro:assets'
import Icon from '@components/ui/Icon.astro'
import Badge from '@components/ui/Badge.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'
import { providerDisplayMeta } from '@lib/providerPresentation'
import type { ReviewSummary } from '@lib/queries/reviews'
import type { ProviderListItem } from '@lib/queries/providers'
import { providerUrl } from '@lib/slug'

interface Props {
  provider: ProviderListItem
  reviewSummary?: ReviewSummary
}

const { provider, reviewSummary } = Astro.props
const displayMeta = providerDisplayMeta(provider, reviewSummary)
---

<article class="civic-card civic-card-hover grid gap-4 p-4 md:grid-cols-[1fr_auto]">
  <div class="flex gap-4">
    <div class="h-16 w-16 shrink-0 overflow-hidden rounded-civic border border-rule bg-surface">
      {
        provider.photo_url ? (
          <Image
            class="h-full w-full object-cover"
            src={provider.photo_url}
            alt={`Foto de ${provider.name}`}
            width={180}
            height={180}
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-canopy-ink to-canopy text-[10px] font-semibold uppercase tracking-[0.5px] text-white/60">
            Foto
          </div>
        )
      }
    </div>
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <h2 class="text-base font-semibold tracking-[-0.2px]">
          <a class="text-ink no-underline hover:text-canopy" href={providerUrl(provider.id, provider.name)}>
          {provider.name}
          </a>
        </h2>
        <Badge label="Verificado" labelEn="Verified" />
      </div>
      <p class="mt-2 text-sm leading-6 text-ink/75">
        {
          provider.description ?? (
            <TranslatedText
              es="Proveedor local verificado disponible en este distrito."
              en="Verified local provider available in this district."
            />
          )
        }
      </p>
      <div class="mt-2 flex flex-wrap gap-3 font-mono text-[11px] uppercase tracking-[0.5px] text-ink-3">
        <span class="flex items-center gap-1 text-star"><Icon name="star" size={11} /> {displayMeta.rating} <span class="text-ink-3">({displayMeta.reviewCount})</span></span>
        <span>{displayMeta.yearsActive} <TranslatedText es="años" en="yrs" /></span>
        <span>{displayMeta.completedJobs} <TranslatedText es="trabajos" en="jobs" /></span>
        <span class="flex items-center gap-1"><Icon name="clock" size={11} /> <TranslatedText es={displayMeta.responseTimeEs} en={displayMeta.responseTimeEn} /></span>
      </div>
    </div>
  </div>
  <div class="flex flex-wrap gap-2 md:flex-col md:items-stretch md:justify-end">
    {provider.whatsapp && (
      <a class="civic-button gap-2 bg-whatsapp text-white" href={`https://wa.me/${provider.whatsapp.replace(/\D/g, '')}`}>
        <Icon name="wa" size={14} /><span>WhatsApp</span>
      </a>
    )}
    <a class="civic-button gap-2 border border-rule bg-surface text-ink" href={`tel:${provider.phone}`}>
      <Icon name="phone" size={14} /><span><TranslatedText es="Llamar" en="Call" /></span>
    </a>
  </div>
</article>

---
import { t } from '@lib/i18n'
---

<footer class="mt-10 border-t border-rule bg-surface-alt px-4 py-8 md:px-6">
  <div class="mx-auto grid max-w-6xl gap-8 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <a class="text-sm font-bold text-ink no-underline hover:text-canopy" href="/">
        DirectorioLocal<span class="text-canopy">.cr</span>
      </a>
      <p class="mt-2 max-w-xs text-sm leading-6 text-ink-3">
        El directorio de servicios verificados de Costa Rica, organizado por cantón y distrito.
      </p>
    </div>

    <nav aria-label="Directorio">
      <p class="civic-meta mb-3">{t('footer.directory')}</p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#districts">{t('nav.cantons')}</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#categories">{t('nav.categories')}</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/aserri/vuelta-de-jorco/">{t('footer.popularDistricts')}</a></li>
      </ul>
    </nav>

    <nav aria-label="Proveedores">
      <p class="civic-meta mb-3">{t('signup.forProviders')}</p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/register-provider/">{t('signup.cta')}</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#provider-signup">FAQ</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#provider-signup">{t('footer.verification')}</a></li>
      </ul>
    </nav>

    <nav aria-label="Legal">
      <p class="civic-meta mb-3">Legal</p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#terms">{t('footer.terms')}</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#privacy">{t('footer.privacy')}</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#report">{t('footer.report')}</a></li>
      </ul>
    </nav>
  </div>

  <div class="mx-auto mt-8 flex max-w-6xl flex-col gap-2 border-t border-rule pt-4 font-mono text-[11px] text-ink-3 sm:flex-row sm:justify-between">
    <span>© 2026 DirectorioLocal.cr</span>
    <span>{t('footer.madeIn')}</span>
  </div>
</footer>

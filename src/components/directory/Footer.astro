---
import TranslatedText from '@components/i18n/TranslatedText.astro'
---

<footer class="mt-10 border-t border-rule bg-surface-alt px-4 py-8 md:px-6">
  <div class="mx-auto grid max-w-6xl gap-8 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <a class="text-sm font-bold text-ink no-underline hover:text-canopy" href="/">
        DirectorioLocal<span class="text-canopy">.cr</span>
      </a>
      <p class="mt-2 max-w-xs text-sm leading-6 text-ink-3">
        <TranslatedText
          es="El directorio de servicios verificados de Costa Rica, organizado por cantón y distrito."
          en="Costa Rica's verified services directory, organized by canton and district."
        />
      </p>
    </div>

    <nav aria-label="Directorio">
      <p class="civic-meta mb-3"><TranslatedText es="Directorio" en="Directory" /></p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#districts"><TranslatedText es="Cantones" en="Cantons" /></a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#categories"><TranslatedText es="Categorías" en="Categories" /></a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/aserri/vuelta-de-jorco/"><TranslatedText es="Distritos populares" en="Popular districts" /></a></li>
      </ul>
    </nav>

    <nav aria-label="Proveedores">
      <p class="civic-meta mb-3"><TranslatedText es="Para proveedores" en="For providers" /></p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/registrar-proveedor/"><TranslatedText es="Registrarme" en="Register" /></a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#provider-signup">FAQ</a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#provider-signup"><TranslatedText es="Verificación" en="Verification" /></a></li>
      </ul>
    </nav>

    <nav aria-label="Legal">
      <p class="civic-meta mb-3">Legal</p>
      <ul class="grid gap-2 text-sm">
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#terms"><TranslatedText es="Términos" en="Terms" /></a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#privacy"><TranslatedText es="Privacidad" en="Privacy" /></a></li>
        <li><a class="text-ink-2 no-underline hover:text-canopy" href="/#report"><TranslatedText es="Reportar" en="Report" /></a></li>
      </ul>
    </nav>
  </div>

  <div class="mx-auto mt-8 flex max-w-6xl flex-col gap-2 border-t border-rule pt-4 font-mono text-[11px] text-ink-3 sm:flex-row sm:justify-between">
    <span>© 2026 DirectorioLocal.cr</span>
    <span><TranslatedText es="Hecho en Costa Rica" en="Made in Costa Rica" /></span>
  </div>
</footer>

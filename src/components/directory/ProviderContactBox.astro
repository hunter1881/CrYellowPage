---
import Icon from '@components/ui/Icon.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'

interface Props {
  phone: string
  whatsapp?: string | null
  responseTimeEs?: string | null
  responseTimeEn?: string | null
  acceptsSinpe?: boolean
  worksWeekends?: boolean
}

const {
  phone,
  whatsapp,
  responseTimeEs = null,
  responseTimeEn = null,
  acceptsSinpe = true,
  worksWeekends = true,
} = Astro.props
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : null
---

<aside class="md:sticky md:top-24 md:self-start">
  <div class="rounded-civic border-2 border-ink bg-surface p-4">
    <p class="civic-meta mb-4">
      <TranslatedText es="Contactar al proveedor" en="Contact provider" />
    </p>
    {
      whatsappUrl && (
        <a class="civic-button w-full gap-2 bg-whatsapp py-3 text-white" href={whatsappUrl}>
          <Icon name="wa" size={16} /><span>WhatsApp</span>
        </a>
      )
    }
    <a class="civic-button mt-2 w-full gap-2 border-2 border-ink bg-surface py-3 text-ink" href={`tel:${phone}`}>
      <Icon name="phone" size={15} /><span>{phone}</span>
    </a>
    <div class="mt-4 border-t border-rule-soft pt-4 text-sm leading-7 text-ink-2">
      <div>
        ✓ <TranslatedText es="Identidad confirmada" en="Identity confirmed" />
      </div>
      <div>
        ✓ <TranslatedText es="Atiende esta zona" en="Serves this area" />
      </div>
      {responseTimeEs !== null && (
        <div>
          ✓ <TranslatedText es={`Responde en ${responseTimeEs}`} en={`Replies in ${responseTimeEn!}`} />
        </div>
      )}
      {
        acceptsSinpe && (
          <div>
            ✓ <TranslatedText es="Acepta SINPE Móvil" en="Accepts SINPE Movil" />
          </div>
        )
      }
      {
        worksWeekends && (
          <div>
            ✓ <TranslatedText es="Atiende fines de semana" en="Works weekends" />
          </div>
        )
      }
    </div>
    <p class="mt-4 border-t border-rule-soft pt-3 text-xs leading-5 text-ink-3">
      <TranslatedText
        es="Identidad confirmada por DirectorioLocal. Verifique precio y disponibilidad directamente con el proveedor."
        en="Identity confirmed by DirectorioLocal. Confirm price and availability directly with the provider."
      />
    </p>
  </div>
  <a class="mt-3 block p-2 text-center font-mono text-[11px] font-semibold uppercase tracking-[0.5px] text-ink-3 no-underline hover:text-canopy" href="#report">
    <TranslatedText es="Reportar información" en="Report information" />
  </a>
</aside>

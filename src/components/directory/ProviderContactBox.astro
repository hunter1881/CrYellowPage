---
import Button from '@components/ui/Button.astro'
import Icon from '@components/ui/Icon.astro'
import { t } from '@lib/i18n'

interface Props {
  phone: string
  whatsapp?: string | null
  responseTimeEs?: string | null
  responseTimeEn?: string | null
  acceptsSinpe?: boolean | null
  worksWeekends?: boolean | null
}

const {
  phone,
  whatsapp,
  responseTimeEs = null,
  acceptsSinpe = null,
  worksWeekends = null,
} = Astro.props
const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : null
---

<aside class="md:sticky md:top-24 md:self-start">
  <div class="rounded-civic border-2 border-ink bg-surface p-4">
    <p class="civic-meta mb-4">
      {t('contact.heading')}
    </p>
    {whatsappUrl && (
      <Button variant="whatsapp" href={whatsappUrl} full class="gap-2 py-3">
        <Icon name="wa" size={16} /><span>WhatsApp</span>
      </Button>
    )}
    <Button variant="outline" href={`tel:${phone}`} full class="mt-2 gap-2 py-3">
      <Icon name="phone" size={15} /><span>{phone}</span>
    </Button>
    <div class="mt-4 border-t border-rule-soft pt-4 text-sm leading-7 text-ink-2">
      <div>✓ {t('contact.identityConfirmed')}</div>
      <div>✓ {t('contact.servesArea')}</div>
      {responseTimeEs !== null && (
        <div>✓ {`Responde en ${responseTimeEs}`}</div>
      )}
      {acceptsSinpe && (
        <div>✓ {t('contact.acceptsSinpe')}</div>
      )}
      {worksWeekends && (
        <div>✓ {t('contact.worksWeekends')}</div>
      )}
    </div>
    <p class="mt-4 border-t border-rule-soft pt-3 text-xs leading-5 text-ink-3">
      {t('contact.disclaimer')}
    </p>
  </div>
  <a class="mt-3 block p-2 text-center font-mono text-[11px] font-semibold uppercase tracking-[0.5px] text-ink-3 no-underline hover:text-canopy" href="#report">
    {t('contact.report')}
  </a>
</aside>

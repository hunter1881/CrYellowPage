---
export interface ChipOption {
  value: string
  label: string
}

interface Props {
  name: string
  label: string
  options: ChipOption[]
  selected?: string[]
  required?: boolean
  max?: number
  placeholder?: string
  error?: string
}

const {
  name,
  label,
  options,
  selected = [],
  required = false,
  max = 50,
  placeholder = 'Buscar y seleccionar…',
  error,
} = Astro.props
---

<div
  class="grid gap-1.5"
  data-chip-select
  data-name={name}
  data-max={String(max)}
  data-selected={JSON.stringify(selected)}
  data-placeholder={placeholder}
>
  <label class="text-sm font-semibold text-ink">
    {label}{required && <span class="ml-0.5 text-clay">*</span>}
  </label>

  <div class="relative">
    {/* Chip bag + search input */}
    <div
      class="flex min-h-[44px] flex-wrap gap-1.5 rounded-civic border border-rule bg-surface px-2.5 py-2 cursor-text focus-within:border-ink transition-colors"
      data-chip-field
    >
      <input
        type="text"
        class="min-w-[120px] flex-1 bg-transparent text-sm outline-none placeholder:text-ink-3"
        autocomplete="off"
        placeholder={placeholder}
        data-chip-text
        aria-autocomplete="list"
        aria-haspopup="listbox"
      />
    </div>

    {/* Filtered dropdown */}
    <ul
      class="absolute left-0 right-0 top-full z-50 mt-1 hidden max-h-56 overflow-y-auto rounded-civic border border-rule bg-surface shadow-civic-lg"
      data-chip-dropdown
      role="listbox"
    ></ul>
  </div>

  {/* Hidden inputs injected here by the script for form submission */}
  <div data-chip-hidden></div>

  {error && <span class="text-xs font-medium text-clay">{error}</span>}

  {/* Options data scoped to this instance */}
  <script type="application/json" data-chip-option-list set:html={JSON.stringify(options)} />
</div>

<script>
  function norm(s: string): string {
    return s
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .replace(/[ñÑ]/g, 'n')
      .toLowerCase()
  }

  interface ChipOption {
    value: string
    label: string
  }

  function initChipSelect(root: HTMLElement): void {
    if (root.dataset.chipInit === '1') return
    root.dataset.chipInit = '1'

    const fieldName = root.dataset.name!
    const max = parseInt(root.dataset.max ?? '50', 10)
    const defaultPlaceholder = root.dataset.placeholder ?? 'Buscar y seleccionar…'

    const field = root.querySelector<HTMLElement>('[data-chip-field]')!
    const textInput = root.querySelector<HTMLInputElement>('[data-chip-text]')!
    const dropdown = root.querySelector<HTMLUListElement>('[data-chip-dropdown]')!
    const hiddenContainer = root.querySelector<HTMLElement>('[data-chip-hidden]')!
    const optionsEl = root.querySelector<HTMLScriptElement>('[data-chip-option-list]')

    const allOptions: ChipOption[] = optionsEl
      ? (JSON.parse(optionsEl.textContent ?? '[]') as ChipOption[])
      : []
    const selected = new Set<string>(JSON.parse(root.dataset.selected ?? '[]') as string[])
    const labelMap = new Map(allOptions.map((o) => [o.value, o.label]))

    // Render pre-selected chips (edit form)
    selected.forEach((v) => addChipDOM(v))
    syncPlaceholder()

    function addChipDOM(value: string): void {
      const lbl = labelMap.get(value) ?? value

      // Hidden input for form submission
      const hidden = document.createElement('input')
      hidden.type = 'hidden'
      hidden.name = fieldName
      hidden.value = value
      hiddenContainer.appendChild(hidden)

      // Chip pill
      const chip = document.createElement('span')
      chip.dataset.chipValue = value
      chip.className =
        'inline-flex items-center gap-1 rounded-full bg-canopy-soft px-2.5 py-1 text-xs font-semibold text-canopy-ink'

      const text = document.createElement('span')
      text.textContent = lbl

      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className =
        'ml-0.5 rounded-full p-0.5 leading-none hover:bg-canopy/20 focus:outline-none'
      btn.setAttribute('aria-label', `Quitar ${lbl}`)
      btn.textContent = '✕'
      btn.addEventListener('click', () => remove(value))

      chip.appendChild(text)
      chip.appendChild(btn)
      field.insertBefore(chip, textInput)
    }

    function remove(value: string): void {
      selected.delete(value)
      // Remove chip (iterate to avoid CSS selector escaping concerns)
      for (const el of Array.from(field.querySelectorAll<HTMLElement>('[data-chip-value]'))) {
        if (el.dataset.chipValue === value) {
          el.remove()
          break
        }
      }
      // Remove hidden input
      for (const el of Array.from(hiddenContainer.querySelectorAll<HTMLInputElement>('input'))) {
        if (el.value === value) {
          el.remove()
          break
        }
      }
      syncPlaceholder()
    }

    function syncPlaceholder(): void {
      textInput.placeholder = selected.size === 0 ? defaultPlaceholder : ''
    }

    function renderDropdown(items: ChipOption[]): void {
      dropdown.innerHTML = ''
      const available = items.filter((o) => !selected.has(o.value))
      if (!available.length) {
        dropdown.classList.add('hidden')
        return
      }
      available.forEach((opt) => {
        const li = document.createElement('li')
        li.setAttribute('role', 'option')
        li.className =
          'flex cursor-pointer items-center px-4 py-2.5 text-sm text-ink hover:bg-surface-alt'
        li.textContent = opt.label
        li.addEventListener('mousedown', (e) => {
          e.preventDefault()
          if (selected.size >= max) return
          selected.add(opt.value)
          addChipDOM(opt.value)
          textInput.value = ''
          dropdown.classList.add('hidden')
          syncPlaceholder()
        })
        dropdown.appendChild(li)
      })
      dropdown.classList.remove('hidden')
    }

    function showFiltered(): void {
      const q = norm(textInput.value)
      if (q) {
        const matches = allOptions.filter((o) => norm(o.label).includes(q)).slice(0, 20)
        renderDropdown(matches)
      } else {
        // Show all unselected options when the field is empty
        renderDropdown(allOptions.slice(0, 50))
      }
    }

    textInput.addEventListener('input', showFiltered)

    textInput.addEventListener('focus', showFiltered)

    textInput.addEventListener('blur', () => {
      setTimeout(() => dropdown.classList.add('hidden'), 150)
      textInput.value = ''
    })

    // Click anywhere in the chip bag focuses the input
    field.addEventListener('click', () => textInput.focus())
  }

  function initAll(): void {
    document.querySelectorAll<HTMLElement>('[data-chip-select]').forEach(initChipSelect)
  }

  document.addEventListener('astro:page-load', initAll)
  initAll()
</script>

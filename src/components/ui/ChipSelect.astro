---
export interface ChipOption {
  value: string
  label: string
}

interface Props {
  name: string
  label: string
  options: ChipOption[]
  selected?: string[]
  required?: boolean
  max?: number
  placeholder?: string
  error?: string
}

const {
  name,
  label,
  options,
  selected = [],
  required = false,
  max = 50,
  placeholder = 'Buscar y seleccionar…',
  error,
} = Astro.props
---

<chip-select
  class="grid gap-1.5"
  data-name={name}
  data-max={String(max)}
  data-selected={JSON.stringify(selected)}
  data-placeholder={placeholder}
  data-options={JSON.stringify(options)}
>
  <label class="text-sm font-semibold text-ink">
    {label}{required && <span class="ml-0.5 text-clay">*</span>}
  </label>

  <div class="relative">
    <div
      class="flex min-h-[44px] flex-wrap gap-1.5 rounded-civic border border-rule bg-surface px-2.5 py-2 cursor-text focus-within:border-ink transition-colors"
      data-chip-field
    >
      <input
        type="text"
        class="min-w-[120px] flex-1 bg-transparent text-sm outline-none placeholder:text-ink-3"
        autocomplete="off"
        placeholder={placeholder}
        data-chip-text
        aria-autocomplete="list"
        aria-haspopup="listbox"
      />
    </div>

    <ul
      class="absolute left-0 right-0 top-full z-50 mt-1 hidden max-h-56 overflow-y-auto rounded-civic border border-rule bg-surface shadow-civic-lg"
      data-chip-dropdown
      role="listbox"
    ></ul>
  </div>

  <div data-chip-hidden></div>

  {error && <span class="text-xs font-medium text-clay">{error}</span>}
</chip-select>

<script>
  type ChipOption = { value: string; label: string }

  function normalize(value: string): string {
    return value
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .replace(/[ñÑ]/g, 'n')
      .toLowerCase()
  }

  class ChipSelectElement extends HTMLElement {
    private fieldName = ''
    private max = 50
    private defaultPlaceholder = 'Buscar y seleccionar…'
    private allOptions: ChipOption[] = []
    private labelMap = new Map<string, string>()
    private selected = new Set<string>()
    private field!: HTMLElement
    private textInput!: HTMLInputElement
    private dropdown!: HTMLUListElement
    private hiddenContainer!: HTMLElement

    connectedCallback() {
      const field = this.querySelector<HTMLElement>('[data-chip-field]')
      const textInput = this.querySelector<HTMLInputElement>('[data-chip-text]')
      const dropdown = this.querySelector<HTMLUListElement>('[data-chip-dropdown]')
      const hiddenContainer = this.querySelector<HTMLElement>('[data-chip-hidden]')
      if (!field || !textInput || !dropdown || !hiddenContainer) return

      this.field = field
      this.textInput = textInput
      this.dropdown = dropdown
      this.hiddenContainer = hiddenContainer
      this.fieldName = this.dataset.name ?? ''
      this.max = parseInt(this.dataset.max ?? '50', 10)
      this.defaultPlaceholder = this.dataset.placeholder ?? this.defaultPlaceholder
      this.allOptions = this.parseJson<ChipOption[]>(this.dataset.options, [])
      this.labelMap = new Map(this.allOptions.map((o) => [o.value, o.label]))
      this.selected = new Set(this.parseJson<string[]>(this.dataset.selected, []))

      this.selected.forEach((v) => this.addChip(v))
      this.syncPlaceholder()

      this.textInput.addEventListener('input', this.handleFilter)
      this.textInput.addEventListener('focus', this.handleFilter)
      this.textInput.addEventListener('blur', this.handleBlur)
      this.field.addEventListener('click', this.focusInput)
    }

    private parseJson<T>(raw: string | undefined, fallback: T): T {
      if (!raw) return fallback
      try {
        return JSON.parse(raw) as T
      } catch {
        return fallback
      }
    }

    private focusInput = () => this.textInput.focus()

    private handleFilter = () => {
      const q = normalize(this.textInput.value)
      if (q) {
        this.renderDropdown(
          this.allOptions.filter((o) => normalize(o.label).includes(q)).slice(0, 20),
        )
      } else {
        this.renderDropdown(this.allOptions.slice(0, 50))
      }
    }

    private handleBlur = () => {
      window.setTimeout(() => this.dropdown.classList.add('hidden'), 150)
      this.textInput.value = ''
    }

    private addChip(value: string) {
      const lbl = this.labelMap.get(value) ?? value

      const hidden = document.createElement('input')
      hidden.type = 'hidden'
      hidden.name = this.fieldName
      hidden.value = value
      this.hiddenContainer.appendChild(hidden)

      const chip = document.createElement('span')
      chip.dataset.chipValue = value
      chip.className =
        'inline-flex items-center gap-1 rounded-full bg-canopy-soft px-2.5 py-1 text-xs font-semibold text-canopy-ink'

      const text = document.createElement('span')
      text.textContent = lbl

      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className =
        'ml-0.5 rounded-full p-0.5 leading-none hover:bg-canopy/20 focus:outline-none'
      btn.setAttribute('aria-label', `Quitar ${lbl}`)
      btn.textContent = '✕'
      btn.addEventListener('click', () => this.removeChip(value))

      chip.append(text, btn)
      this.field.insertBefore(chip, this.textInput)
    }

    private removeChip(value: string) {
      this.selected.delete(value)
      for (const el of this.field.querySelectorAll<HTMLElement>('[data-chip-value]')) {
        if (el.dataset.chipValue === value) {
          el.remove()
          break
        }
      }
      for (const el of this.hiddenContainer.querySelectorAll<HTMLInputElement>('input')) {
        if (el.value === value) {
          el.remove()
          break
        }
      }
      this.syncPlaceholder()
    }

    private syncPlaceholder() {
      this.textInput.placeholder = this.selected.size === 0 ? this.defaultPlaceholder : ''
    }

    private renderDropdown(items: ChipOption[]) {
      this.dropdown.replaceChildren()
      const available = items.filter((o) => !this.selected.has(o.value))
      if (!available.length) {
        this.dropdown.classList.add('hidden')
        return
      }
      for (const opt of available) {
        const li = document.createElement('li')
        li.setAttribute('role', 'option')
        li.className =
          'flex cursor-pointer items-center px-4 py-2.5 text-sm text-ink hover:bg-surface-alt'
        li.textContent = opt.label
        li.addEventListener('mousedown', (event) => {
          event.preventDefault()
          if (this.selected.size >= this.max) return
          this.selected.add(opt.value)
          this.addChip(opt.value)
          this.textInput.value = ''
          this.dropdown.classList.add('hidden')
          this.syncPlaceholder()
        })
        this.dropdown.appendChild(li)
      }
      this.dropdown.classList.remove('hidden')
    }
  }

  if (!customElements.get('chip-select')) {
    customElements.define('chip-select', ChipSelectElement)
  }
</script>

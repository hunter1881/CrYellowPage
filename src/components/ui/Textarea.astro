---
interface Props {
  label?: string
  name: string
  value?: string | null
  placeholder?: string
  required?: boolean
  rows?: number
  minlength?: number
  maxlength?: number
  error?: string
  hint?: string
  class?: string
  [key: string]: unknown
}

const {
  label,
  name,
  value,
  placeholder,
  required = false,
  rows = 4,
  minlength,
  maxlength,
  error,
  hint,
  class: className = '',
  ...rest
} = Astro.props
---

<div class:list={['form-control w-full', className]}>
  {label && (
    <label class="label pb-1" for={name}>
      <span class="label-text text-sm font-semibold text-ink">
        {label}{required && <span class="ml-0.5 text-clay">*</span>}
      </span>
    </label>
  )}
  <textarea
    class:list={[
      'w-full rounded-civic border bg-surface px-3 py-2 text-sm font-normal leading-6 text-ink outline-none focus:border-canopy placeholder:text-ink-3',
      error ? 'border-clay' : 'border-rule',
    ]}
    id={name}
    name={name}
    rows={rows}
    placeholder={placeholder}
    required={required || undefined}
    minlength={minlength}
    maxlength={maxlength}
    {...rest}
  >{value ?? ''}</textarea>
  {error && (
    <div class="label pt-1">
      <span class="label-text-alt font-medium text-clay">{error}</span>
    </div>
  )}
  {hint && !error && (
    <div class="label pt-1">
      <span class="label-text-alt text-ink-3">{hint}</span>
    </div>
  )}
</div>

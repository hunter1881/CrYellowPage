---
type Variant = 'verified' | 'pending' | 'category'

interface Props {
  label: string
  variant?: Variant
}

const { label, variant = 'verified' } = Astro.props

const variantClasses: Record<Variant, string> = {
  verified: 'bg-canopy-soft text-canopy',
  pending:  'bg-clay-soft text-clay',
  category: 'bg-surface text-ink-2 border border-rule',
}
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-civic px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.5px]',
    variantClasses[variant],
  ]}
>
  {variant === 'verified' && <span aria-hidden="true">✓</span>}
  {label}
</span>

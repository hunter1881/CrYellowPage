---
interface Props {
  label?: string
  name: string
  value?: string | null
  required?: boolean
  error?: string
  hint?: string
  class?: string
  [key: string]: unknown
}

const {
  label,
  name,
  value,
  required = false,
  error,
  hint,
  class: className = '',
  ...rest
} = Astro.props
---

<div class:list={['form-control w-full', className]}>
  {label && (
    <label class="label pb-1" for={name}>
      <span class="label-text text-sm font-semibold text-ink">{label}</span>
    </label>
  )}
  <select
    class:list={[
      'w-full rounded-civic border bg-surface px-3 py-2 text-sm font-normal text-ink outline-none focus:border-canopy',
      error ? 'border-clay' : 'border-rule',
    ]}
    id={name}
    name={name}
    required={required || undefined}
    {...rest}
  >
    <slot />
  </select>
  {error && (
    <div class="label pt-1">
      <span class="label-text-alt font-medium text-clay">{error}</span>
    </div>
  )}
  {hint && !error && (
    <div class="label pt-1">
      <span class="label-text-alt text-ink-3">{hint}</span>
    </div>
  )}
</div>

---
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import StatsStrip from '@components/directory/StatsStrip.astro'
import type { BreadcrumbItem } from '@lib/seo/breadcrumb'

interface StatItem {
  label: string
  value: string | number
}

interface Props {
  breadcrumbs?: BreadcrumbItem[]
  meta: string
  heading: string
  intro: string
  stats?: StatItem[]
  /** Padding vertical del contenedor interior. Default: 'py-6' */
  py?: string
}

const { breadcrumbs, meta, heading, intro, stats, py = 'py-6' } = Astro.props
---

<section class="border-b border-rule bg-surface">
  <div class={`mx-auto max-w-6xl px-4 ${py} md:px-6`}>
    {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
    <p class="civic-meta mt-5">{meta}</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-[-0.5px] text-ink md:text-4xl">
      {heading}
    </h1>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
      {intro}
    </p>
    {stats && (
      <div class="mt-5">
        <StatsStrip items={stats} />
      </div>
    )}
    <slot />
  </div>
</section>

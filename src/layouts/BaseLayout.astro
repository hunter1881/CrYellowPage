---
import { ClientRouter } from 'astro:transitions'
import '@styles/global.css'
import Footer from '@components/directory/Footer.astro'
import LocationModal from '@components/directory/LocationModal.astro'
import MobileDrawer from '@components/directory/MobileDrawer.astro'
import { defaultDescription, siteName } from '@lib/site'
import { getCantonsWithDistricts } from '@lib/queries/geography'
import { t } from '@lib/i18n'

interface Props {
  title?: string
  titleEn?: string
  description?: string
  descriptionEn?: string
  canonical?: string
  image?: string
  ogType?: 'website' | 'article'
  jsonLd?: unknown | unknown[]
}

const {
  title = siteName,
  description = defaultDescription,
  canonical = Astro.url.href,
  image = new URL('/og-default.png', Astro.site ?? Astro.url).href,
  ogType = 'website',
  jsonLd,
} = Astro.props

const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []
const cantons = await getCantonsWithDistricts()
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      jsonLdItems.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 border-b border-rule bg-surface">
      <div class="hidden bg-canopy-ink px-6 py-1 text-[11px] text-white/75 md:block">
        <div class="mx-auto flex max-w-6xl justify-between font-mono tracking-[0.3px]">
          <span class="uppercase">Directorio local · Costa Rica</span>
          <span class="flex gap-4">
            <a class="text-white/75 no-underline hover:text-white" href="/#provider-signup">
              {t('nav.provider')}
            </a>
            <span>+506 0000-0000</span>
          </span>
        </div>
      </div>
      <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-3 md:px-6">
        <a class="flex items-center gap-3 text-ink no-underline" href="/">
          <span class="flex h-8 w-8 items-center justify-center rounded-civic bg-canopy text-sm font-bold text-white">DL</span>
          <span class="leading-tight">
            <span class="block text-base font-semibold tracking-[-0.3px]">DirectorioLocal<span class="text-canopy">.cr</span></span>
            <span class="hidden font-mono text-[11px] uppercase tracking-[0.5px] text-ink-3 md:block">
              {t('layout.tagline')}
            </span>
          </span>
        </a>
        <nav class="ml-auto hidden items-center gap-5 text-sm font-medium md:flex" aria-label="Primary">
          <a class="text-ink-2 no-underline hover:text-canopy" href="/#cantones">
            {t('nav.cantons')}
          </a>
          <a class="text-ink-2 no-underline hover:text-canopy" href="/#categories">
            {t('nav.categories')}
          </a>
          <a class="text-ink-2 no-underline hover:text-canopy" href="/#provider-signup">
            {t('nav.provider')}
          </a>
          <a class="text-ink-2 no-underline hover:text-canopy" href="/account/">
            {t('nav.account')}
          </a>
        </nav>
        <button
          class="hidden rounded-civic border border-rule px-3 py-2 text-xs font-semibold text-ink-2 hover:text-canopy md:inline-flex"
          type="button"
          data-open-location
        >
          {t('nav.changeLocation')}
        </button>
        <button
          class="inline-flex h-9 w-9 items-center justify-center rounded-civic border border-rule text-ink md:hidden"
          type="button"
          data-open-mobile-menu
          aria-label="Abrir menu"
        >
          <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="18" height="18" aria-hidden="true"><path d="M3 5h12M3 9h12M3 13h12"/></svg>
        </button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <Footer />
    <MobileDrawer />
    <LocationModal cantons={cantons} />
    <script is:inline>
      function setLayerOpen(element, open, displayClass) {
        if (!element) return
        element.classList.toggle('hidden', !open)
        if (displayClass) element.classList.toggle(displayClass, open)
        element.setAttribute('aria-hidden', open ? 'false' : 'true')
        document.body.classList.toggle('overflow-hidden', open)
      }

      function closeLayers() {
        setLayerOpen(document.querySelector('[data-mobile-drawer]'), false)
        setLayerOpen(document.querySelector('[data-location-modal]'), false, 'flex')
      }

      document.addEventListener('change', (event) => {
        const select = event.target?.closest?.('[data-sort-select]')
        if (!select?.value) return
        window.location.assign(select.value)
      })

      document.querySelectorAll('[data-open-mobile-menu]').forEach((button) => {
        button.addEventListener('click', () => {
          setLayerOpen(document.querySelector('[data-mobile-drawer]'), true)
        })
      })

      document.querySelectorAll('[data-close-mobile-menu]').forEach((button) => {
        button.addEventListener('click', closeLayers)
      })

      document.querySelectorAll('[data-open-location]').forEach((button) => {
        button.addEventListener('click', () => {
          setLayerOpen(document.querySelector('[data-mobile-drawer]'), false)
          setLayerOpen(document.querySelector('[data-location-modal]'), true, 'flex')
        })
      })

      document.querySelectorAll('[data-close-location]').forEach((button) => {
        button.addEventListener('click', closeLayers)
      })

      // Search bar location picker — opens modal in 'select' mode
      document.querySelectorAll('[data-open-search-location]').forEach((button) => {
        button.addEventListener('click', () => {
          const modal = document.querySelector('[data-location-modal]')
          if (modal) modal.dataset.searchMode = '1'
          setLayerOpen(document.querySelector('[data-mobile-drawer]'), false)
          setLayerOpen(document.querySelector('[data-location-modal]'), true, 'flex')
        })
      })

      // Intercept district link clicks when modal is in search mode
      document.querySelector('[data-location-modal]')?.addEventListener('click', (event) => {
        const modal = document.querySelector('[data-location-modal]')
        if (!modal?.dataset.searchMode) return
        const link = event.target?.closest('[data-location-option]')
        if (!link) return
        event.preventDefault()
        const href = link.getAttribute('href') ?? ''
        const cleanPath = href.replace(/^\//,'').replace(/\/$/,'')
        const districtText = link.querySelector('span')?.textContent?.trim() ?? cleanPath
        const districtId = link.dataset.districtId ?? ''
        document.querySelectorAll('[data-search-district-input]').forEach((input) => {
          input.value = cleanPath
        })
        document.querySelectorAll('[data-search-district-id-input]').forEach((input) => {
          input.value = districtId
        })
        document.querySelectorAll('[data-search-location-label]').forEach((label) => {
          label.textContent = districtText
        })
        delete modal.dataset.searchMode
        closeLayers()
      })

      document.querySelectorAll('[data-mobile-drawer], [data-location-modal]').forEach((layer) => {
        layer.addEventListener('click', (event) => {
          if (event.target === layer) {
            const modal = document.querySelector('[data-location-modal]')
            if (modal) delete modal.dataset.searchMode
            closeLayers()
          }
        })
      })

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLayers()
      })

      document.querySelectorAll('[data-location-filter]').forEach((input) => {
        input.addEventListener('input', () => {
          const query = input.value.toLowerCase().trim()
          document.querySelectorAll('[data-location-option]').forEach((option) => {
            const matches = option.dataset.locationText?.toLowerCase().includes(query) ?? true
            option.hidden = !matches
          })
          document.querySelectorAll('[data-location-group]').forEach((group) => {
            group.querySelectorAll('[data-location-subgroup]').forEach((subgroup) => {
              const hasVisibleOption = [...subgroup.querySelectorAll('[data-location-option]')].some(
                (option) => !option.hidden,
              )
              subgroup.hidden = !hasVisibleOption
            })
            const hasVisibleOption = [...group.querySelectorAll('[data-location-option]')].some(
              (option) => !option.hidden,
            )
            group.hidden = !hasVisibleOption
          })
        })
      })
    </script>
  </body>
</html>

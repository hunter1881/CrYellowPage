---
import { ClientRouter } from 'astro:transitions'
import '@styles/global.css'
import Footer from '@components/directory/Footer.astro'
import MobileBottomBar from '@components/directory/MobileBottomBar.astro'
import MobileDrawer from '@components/directory/MobileDrawer.astro'
import Navbar from '@components/directory/Navbar.astro'
import { defaultDescription, siteName } from '@lib/site'

interface Props {
  title?: string
  titleEn?: string
  description?: string
  descriptionEn?: string
  canonical?: string
  image?: string
  ogType?: 'website' | 'article'
  jsonLd?: unknown | unknown[]
  locationLabel?: string
}

const {
  title = siteName,
  description = defaultDescription,
  canonical = Astro.url.href,
  image = new URL('/og-default.png', Astro.site ?? Astro.url).href,
  ogType = 'website',
  jsonLd,
  locationLabel,
} = Astro.props

const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      jsonLdItems.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    {/* Alpine.js — must load before body so x-data elements initialise correctly */}
    <script>
      import Alpine from 'alpinejs'
      // Re-init Alpine on every Astro page transition (ClientRouter swaps the body)
      document.addEventListener('astro:page-load', () => {
        if (!window._alpineStarted) {
          window._alpineStarted = true
          Alpine.start()
        }
      })
    </script>
  </head>
  <body class="min-h-screen">
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-200 focus:rounded-civic focus:bg-canopy focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:no-underline"
      href="#main-content"
    >
      Saltar al contenido principal
    </a>
    <div id="page-progress" aria-hidden="true"></div>
    <Navbar locationLabel={locationLabel} />
    <main id="main-content" class="pb-16 md:pb-0">
      <slot />
    </main>
    <Footer />
    <MobileBottomBar />
    <MobileDrawer />
    <script is:inline>
      // ── Page progress bar ──────────────────────────────────────────────────
      ;(function () {
        // Guard: is:inline scripts can re-run on back/forward; init only once
        if (window._dlProg) return
        window._dlProg = true

        var started = false

        function getBar() {
          return document.getElementById('page-progress')
        }

        function start() {
          started = true
          var bar = getBar()
          if (!bar) return
          // Phase 1: instant snap to 8% — visible even if page loads in 50ms
          bar.className = 'is-start'
          void bar.offsetWidth // force reflow so phase-2 transition fires from here
          // Phase 2: slow creep toward 85%
          bar.className = 'is-loading'
        }

        function finish() {
          var bar = getBar()
          // Skip the animation on initial page load (start() was never called)
          if (!started) {
            if (bar) bar.className = ''
            return
          }
          started = false
          if (!bar) return
          bar.className = 'is-done'
          bar.addEventListener('transitionend', function onEnd(e) {
            // Wait for the opacity fade to complete before resetting
            if (e.propertyName === 'opacity') {
              bar.className = ''
              bar.removeEventListener('transitionend', onEnd)
            }
          })
          // Clean up any lingering submit-button spinners
          document.querySelectorAll('.btn-loading').forEach(function (btn) {
            btn.classList.remove('btn-loading')
            var sp = btn.querySelector('.btn-spinner')
            if (sp) sp.remove()
          })
        }

        // After body swap, re-apply loading state (transition:persist is unreliable in some modes)
        document.addEventListener('astro:after-swap', function () {
          if (started) {
            var bar = getBar()
            if (bar) bar.className = 'is-loading'
          }
        })

        // Astro View Transition events
        document.addEventListener('astro:before-preparation', start)
        document.addEventListener('astro:page-load', finish)

        // Form submits (Astro Actions POST)
        document.addEventListener('submit', function (event) {
          var form = event.target
          if (!form || form.method?.toLowerCase() === 'get') return
          start()
          var btn = form.querySelector('[type="submit"]')
          if (btn && !btn.classList.contains('btn-loading')) {
            btn.classList.add('btn-loading')
            var spinner = document.createElement('span')
            spinner.className = 'btn-spinner'
            spinner.setAttribute('aria-hidden', 'true')
            btn.appendChild(spinner)
          }
        })
      })()
    </script>
    <script is:inline>
      function setLayerOpen(element, open) {
        if (!element) return
        element.classList.toggle('hidden', !open)
        element.setAttribute('aria-hidden', open ? 'false' : 'true')
        document.body.classList.toggle('overflow-hidden', open)
      }

      function closeLayers() {
        setLayerOpen(document.querySelector('[data-mobile-drawer]'), false)
      }

      document.addEventListener('change', (event) => {
        const select = event.target?.closest?.('[data-sort-select]')
        if (!select?.value) return
        window.location.assign(select.value)
      })

      document.querySelectorAll('[data-open-mobile-menu]').forEach((button) => {
        button.addEventListener('click', () => {
          setLayerOpen(document.querySelector('[data-mobile-drawer]'), true)
        })
      })

      document.querySelectorAll('[data-close-mobile-menu]').forEach((button) => {
        button.addEventListener('click', closeLayers)
      })

      document.querySelector('[data-mobile-drawer]')?.addEventListener('click', (event) => {
        if (event.target === event.currentTarget) closeLayers()
      })

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLayers()
      })
    </script>
  </body>
</html>

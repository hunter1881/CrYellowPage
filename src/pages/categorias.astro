---
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategories } from '@lib/queries/categories'
import { absoluteUrl } from '@lib/site'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'

export const prerender = true

const categories = await getCategories()

const canonical = absoluteUrl('/categorias/', Astro.site)
const breadcrumbs = [
  { name: 'Inicio', url: absoluteUrl('/', Astro.site) },
  { name: 'Categorías', url: canonical },
]
const jsonLd = breadcrumbJsonLd(breadcrumbs)

function norm(s: string) {
  return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
}
---

<BaseLayout
  title="Categorías de servicios | DirectorioLocal CR"
  description="Explore todas las categorías de servicios disponibles en Costa Rica: fontanería, electricidad, limpieza, y más."
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-6 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
      <p class="civic-meta mt-5">Directorio · Servicios</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-[-0.5px] text-ink md:text-4xl">
        Categorías de servicios
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
        {categories.length} categorías disponibles. Busque una categoría y seleccione su cantón y distrito para ver proveedores verificados cerca de usted.
      </p>
    </div>
  </section>

  <div
    class="mx-auto max-w-6xl px-4 py-8 md:px-6"
    x-data="{
      query: '',
      matches(n) {
        if (!this.query.trim()) return true
        return n.includes(this.query.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,''))
      }
    }"
  >
    <!-- Search input -->
    <div class="relative mb-6 max-w-sm">
      <input
        type="search"
        placeholder="Buscar categoría…"
        class="w-full rounded-civic border border-rule bg-surface py-2.5 pl-9 pr-4 text-sm text-ink placeholder:text-ink-3 focus:border-canopy focus:outline-none"
        x-model="query"
        aria-label="Buscar categoría"
      />
      <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
      </svg>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {categories.map((cat) => (
        <a
          href={`/search?q=${encodeURIComponent(cat.name)}`}
          data-norm={norm(cat.name)}
          x-show={`matches('${norm(cat.name)}')`}
          class="civic-card civic-card-hover flex items-center gap-3 p-4 text-ink no-underline"
        >
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-civic bg-canopy-soft text-xl" aria-hidden="true">
            {cat.icon_emoji ?? '#'}
          </span>
          <span class="text-[15px] font-semibold tracking-[-0.1px]">{cat.name}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>


---
import CategoryGrid from '@components/directory/CategoryGrid.astro'
import DistrictLinkList from '@components/directory/DistrictLinkList.astro'
import ProviderSignupCard from '@components/directory/ProviderSignupCard.astro'
import StatsStrip from '@components/directory/StatsStrip.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategoriesByDistrictId } from '@lib/queries/categories'
import { getDistrictBySlugs, getDistrictsByCantonId, getDistrictStaticPaths } from '@lib/queries/geography'
import { absoluteUrl } from '@lib/site'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'
import { placeJsonLd } from '@lib/seo/place'

export const prerender = true

export async function getStaticPaths() {
  return getDistrictStaticPaths()
}

const cantonSlug = Astro.params.canton ?? ''
const districtSlug = Astro.params.distrito ?? ''
const district = await getDistrictBySlugs(cantonSlug, districtSlug)

if (!district) {
  return Astro.redirect('/404')
}

const categories = await getCategoriesByDistrictId(district.id)
const cantonDistricts = await getDistrictsByCantonId(district.canton.id)
const nearbyDistricts = cantonDistricts.filter((item) => item.id !== district.id).slice(0, 5)
const canonical = absoluteUrl(`/${district.canton.slug}/${district.slug}/`, Astro.site)
const breadcrumbs = [
  { name: 'Inicio', url: absoluteUrl('/', Astro.site) },
  { name: district.canton.name, url: absoluteUrl(`/${district.canton.slug}/`, Astro.site) },
  { name: district.name, url: canonical },
]
const jsonLd = [
  placeJsonLd({ name: district.name, parentName: district.canton.name, url: canonical }),
  breadcrumbJsonLd(breadcrumbs),
]
const pageTitleEs = `Servicios locales en ${district.name}, ${district.canton.name}`
const pageTitleEn = `Local Services in ${district.name}, ${district.canton.name}`
const pageDescriptionEs = `Explore categorías de servicios verificados para ${district.name}, ${district.canton.name}, cerca de su comunidad.`
const pageDescriptionEn = `Browse verified service categories for ${district.name}, ${district.canton.name}, near your local community.`
const headingEs = `Servicios locales en ${district.name}`
const headingEn = `Local services in ${district.name}`
const introEs = `Seleccione una categoría para comparar proveedores verificados que atienden ${district.name}, ${district.canton.name}.`
const introEn = `Select a category to compare verified providers serving ${district.name}, ${district.canton.name}.`
---

<BaseLayout
  title={pageTitleEs}
  titleEn={pageTitleEn}
  description={pageDescriptionEs}
  descriptionEn={pageDescriptionEn}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-6 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
      <p class="civic-meta mt-5"><TranslatedText es="Distrito" en="District" /> · {district.canton.name}</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-[-0.5px] text-ink md:text-4xl">
        <TranslatedText es={headingEs} en={headingEn} />
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
        <TranslatedText es={introEs} en={introEn} />
      </p>
      <div class="mt-5">
        <StatsStrip
          items={[
            { labelEs: 'Categorías', labelEn: 'Categories', value: categories.length },
            { labelEs: 'Distrito', labelEn: 'District', value: district.name },
            { labelEs: 'Cantón', labelEn: 'Canton', value: district.canton.name },
            { labelEs: 'Contacto', labelEn: 'Contact', value: 'Directo' },
          ]}
        />
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-6 md:grid-cols-[240px_1fr] md:px-6">
    <aside class="order-2 grid gap-6 md:order-1">
      <DistrictLinkList
        cantonSlug={district.canton.slug}
        districts={cantonDistricts}
        activeDistrictSlug={district.slug}
      />
      <ProviderSignupCard compact />
    </aside>

    <div class="order-1 md:order-2">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold tracking-[-0.3px]"><TranslatedText es="Categorías en este distrito" en="Categories in this district" /></h2>
        <span class="civic-meta">{categories.length} <TranslatedText es="categorías" en="categories" /></span>
      </div>
      <CategoryGrid categories={categories} basePath={`/${district.canton.slug}/${district.slug}`} />

      <div class="mt-8 rounded-civic border border-rule bg-surface-alt p-5">
        <p class="civic-meta"><TranslatedText es="Distritos cercanos" en="Nearby districts" /></p>
        {
          nearbyDistricts.length > 0 ? (
            <div class="mt-3 flex flex-wrap gap-2">
              {nearbyDistricts.map((nearbyDistrict) => (
                <a
                  class="rounded-full border border-rule bg-surface px-3 py-1.5 text-xs font-semibold text-ink-2 no-underline hover:border-canopy hover:text-canopy"
                  href={`/${district.canton.slug}/${nearbyDistrict.slug}/`}
                >
                  {nearbyDistrict.name}
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-2 text-sm leading-6 text-ink-2">
              <TranslatedText es="Aún no hay otros distritos publicados en este cantón." en="No other districts are published in this canton yet." />
            </p>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

---
import CategoryGrid from '@components/directory/CategoryGrid.astro'
import DistrictLinkList from '@components/directory/DistrictLinkList.astro'
import EmptyState from '@components/directory/EmptyState.astro'
import ProviderSignupCard from '@components/directory/ProviderSignupCard.astro'
import StatsStrip from '@components/directory/StatsStrip.astro'
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategoriesWithCountsByDistrictId } from '@lib/queries/categories'
import { getDistrictBySlugs, getDistrictsByCantonId, getDistrictStaticPathsAll } from '@lib/queries/geography'
import { absoluteUrl } from '@lib/site'
import { t, tpl } from '@lib/i18n'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'
import { placeJsonLd } from '@lib/seo/place'

export const prerender = true

export async function getStaticPaths() {
  return getDistrictStaticPathsAll()
}

const cantonSlug = Astro.params.canton ?? ''
const districtSlug = Astro.params.distrito ?? ''
const district = await getDistrictBySlugs(cantonSlug, districtSlug)

if (!district) {
  return Astro.redirect('/404')
}

const categories = await getCategoriesWithCountsByDistrictId(district.id)
const cantonDistricts = await getDistrictsByCantonId(district.canton.id)
const nearbyDistricts = cantonDistricts.filter((item) => item.id !== district.id).slice(0, 5)
const canonical = absoluteUrl(`/${district.canton.slug}/${district.slug}/`, Astro.site)
const breadcrumbs = [
  { name: t('nav.home'), url: absoluteUrl('/', Astro.site) },
  { name: district.canton.name, url: absoluteUrl(`/${district.canton.slug}/`, Astro.site) },
  { name: district.name, url: canonical },
]
const jsonLd = [
  placeJsonLd({ name: district.name, parentName: district.canton.name, url: canonical }),
  breadcrumbJsonLd(breadcrumbs),
]
const pageTitle = tpl('district.pageTitle', { name: district.name, canton: district.canton.name })
const pageDescription = tpl('district.pageDescription', { name: district.name, canton: district.canton.name })
const heading = tpl('district.heading', { name: district.name })
const intro = tpl('district.intro', { name: district.name, canton: district.canton.name })
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-6 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
      <p class="civic-meta mt-5">{t('district.meta')} · {district.canton.name}</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-[-0.5px] text-ink md:text-4xl">
        {heading}
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
        {intro}
      </p>
      <div class="mt-5">
        <StatsStrip
          items={[
            { label: t('stats.providersInDistrict'), value: categories.reduce((sum, cat) => sum + (cat.count ?? 0), 0) },
            { label: t('stats.availableCategories'), value: categories.length },
            { label: t('stats.district'), value: district.name },
            { label: t('stats.canton'), value: district.canton.name },
          ]}
        />
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-6 md:grid-cols-[240px_1fr] md:px-6">
    <aside class="order-2 grid gap-6 md:order-1">
      <DistrictLinkList
        cantonSlug={district.canton.slug}
        districts={cantonDistricts}
        activeDistrictSlug={district.slug}
      />
      <ProviderSignupCard compact />
    </aside>

    <div class="order-1 md:order-2">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold tracking-[-0.3px]">{t('district.categoriesSectionHeading')}</h2>
        {categories.length > 0 && <span class="civic-meta">{categories.length} {t('district.categoriesCount')}</span>}
      </div>
      {categories.length > 0 ? (
        <CategoryGrid categories={categories} basePath={`/${district.canton.slug}/${district.slug}`} />
      ) : (
        <EmptyState
          title={tpl('district.emptyTitle', { name: district.name })}
          body={tpl('district.emptyBody', { name: district.name })}
          actionHref="/register-provider"
        />
      )}

      <div class="mt-8 rounded-civic border border-rule bg-surface-alt p-5">
        <p class="civic-meta">{t('district.nearbySectionHeading')}</p>
        {
          nearbyDistricts.length > 0 ? (
            <div class="mt-3 flex flex-wrap gap-2">
              {nearbyDistricts.map((nearbyDistrict) => (
                <a
                  class="rounded-full border border-rule bg-surface px-3 py-1.5 text-xs font-semibold text-ink-2 no-underline hover:border-canopy hover:text-canopy"
                  href={`/${district.canton.slug}/${nearbyDistrict.slug}/`}
                >
                  {nearbyDistrict.name}
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-2 text-sm leading-6 text-ink-2">
              {t('district.noNearbyCopy')}
            </p>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

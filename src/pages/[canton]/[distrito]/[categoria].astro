---
import EmptyState from '@components/directory/EmptyState.astro'
import FilterPanel from '@components/directory/FilterPanel.astro'
import ProviderCard from '@components/directory/ProviderCard.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategoriesByDistrictId, getCategoryBySlug } from '@lib/queries/categories'
import { getDistrictBySlugs, getDistrictsByCantonId } from '@lib/queries/geography'
import { getListingStaticPaths, getProvidersByDistrictAndCategory } from '@lib/queries/providers'
import { getReviewSummariesByProviderIds } from '@lib/queries/reviews'
import { absoluteUrl } from '@lib/site'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'
import { itemListJsonLd } from '@lib/seo/itemList'
import { providerUrl } from '@lib/slug'

export const prerender = true

export async function getStaticPaths() {
  return getListingStaticPaths()
}

const cantonSlug = Astro.params.canton ?? ''
const districtSlug = Astro.params.distrito ?? ''
const categorySlug = Astro.params.categoria ?? ''
const [district, category, providers] = await Promise.all([
  getDistrictBySlugs(cantonSlug, districtSlug),
  getCategoryBySlug(categorySlug),
  getProvidersByDistrictAndCategory(cantonSlug, districtSlug, categorySlug),
])

if (!district || !category) {
  return Astro.redirect('/404')
}

const [nearbyDistricts, relatedCategories] = await Promise.all([
  getDistrictsByCantonId(district.canton.id),
  getCategoriesByDistrictId(district.id),
])
const reviewSummaries = await getReviewSummariesByProviderIds(providers.map((provider) => provider.id))
const currentParams = Astro.url.searchParams
const activeFilters = {
  sinpe: currentParams.get('sinpe') === '1',
  weekend: currentParams.get('weekend') === '1',
  fast: currentParams.get('fast') === '1',
}
const activeSort = currentParams.get('sort') ?? 'rating'

function listingUrl(nextParams: Record<string, string | null>) {
  const params = new URLSearchParams(currentParams)
  for (const [key, value] of Object.entries(nextParams)) {
    if (value === null) {
      params.delete(key)
    } else {
      params.set(key, value)
    }
  }
  const query = params.toString()
  return query ? `${Astro.url.pathname}?${query}` : Astro.url.pathname
}

const filterOptions = [
  {
    key: 'sinpe',
    es: 'Acepta SINPE',
    en: 'Accepts SINPE',
    active: activeFilters.sinpe,
    href: listingUrl({ sinpe: activeFilters.sinpe ? null : '1' }),
  },
  {
    key: 'weekend',
    es: 'Atiende fines de semana',
    en: 'Works weekends',
    active: activeFilters.weekend,
    href: listingUrl({ weekend: activeFilters.weekend ? null : '1' }),
  },
  {
    key: 'fast',
    es: 'Respuesta rápida',
    en: 'Fast reply',
    active: activeFilters.fast,
    href: listingUrl({ fast: activeFilters.fast ? null : '1' }),
  },
]
const sortOptions = [
  { value: 'rating', es: 'Mejor calificados', en: 'Top rated', active: activeSort === 'rating', href: listingUrl({ sort: 'rating' }) },
  { value: 'newest', es: 'Más recientes', en: 'Newest', active: activeSort === 'newest', href: listingUrl({ sort: 'newest' }) },
  { value: 'fast', es: 'Respuesta rápida', en: 'Fast reply', active: activeSort === 'fast', href: listingUrl({ sort: 'fast' }) },
  { value: 'experience', es: 'Más experiencia', en: 'Most experienced', active: activeSort === 'experience', href: listingUrl({ sort: 'experience' }) },
]
const visibleProviders = providers
  .filter((provider) => !activeFilters.sinpe || provider.accepts_sinpe)
  .filter((provider) => !activeFilters.weekend || provider.works_weekends)
  .filter((provider) => !activeFilters.fast || (provider.response_time_minutes ?? Number.POSITIVE_INFINITY) <= 45)
  .sort((a, b) => {
    if (activeSort === 'newest') return new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
    if (activeSort === 'fast') {
      return (a.response_time_minutes ?? Number.POSITIVE_INFINITY) - (b.response_time_minutes ?? Number.POSITIVE_INFINITY)
    }
    if (activeSort === 'experience') return (b.years_active ?? 0) - (a.years_active ?? 0)

    const ratingDelta = Number(reviewSummaries.get(b.id)?.rating ?? 0) - Number(reviewSummaries.get(a.id)?.rating ?? 0)
    if (ratingDelta !== 0) return ratingDelta
    return (reviewSummaries.get(b.id)?.reviewCount ?? 0) - (reviewSummaries.get(a.id)?.reviewCount ?? 0)
  })
const listingPathKeys = new Set(
  (await getListingStaticPaths()).map((path) => `${path.params.canton}/${path.params.distrito}/${path.params.categoria}`),
)
const nearbyDistrictLinks = nearbyDistricts.filter((item) => item.id !== district.id).slice(0, 5)
const relatedCategoryLinks = relatedCategories
  .filter((item) => item.id !== category.id)
  .filter((item) => listingPathKeys.has(`${district.canton.slug}/${district.slug}/${item.slug}`))
  .slice(0, 5)
const canonical = absoluteUrl(`/${district.canton.slug}/${district.slug}/${category.slug}`, Astro.site)
const breadcrumbs = [
  { name: 'Inicio', url: absoluteUrl('/', Astro.site) },
  { name: district.canton.name, url: absoluteUrl(`/${district.canton.slug}/`, Astro.site) },
  { name: district.name, url: absoluteUrl(`/${district.canton.slug}/${district.slug}/`, Astro.site) },
  { name: category.name, url: canonical },
]
const jsonLd = [
  itemListJsonLd({
    name: `${category.name} in ${district.name}`,
    items: visibleProviders.map((provider) => ({
      name: provider.name,
      url: absoluteUrl(providerUrl(provider.id, provider.name), Astro.site),
    })),
  }),
  breadcrumbJsonLd(breadcrumbs),
]
const pageTitleEs = `${category.name} en ${district.name}, ${district.canton.name}`
const pageTitleEn = `${category.name} in ${district.name}, ${district.canton.name}`
const pageDescriptionEs = `Compare proveedores verificados de ${category.name.toLowerCase()} que atienden ${district.name}, ${district.canton.name}.`
const pageDescriptionEn = `Compare verified ${category.name.toLowerCase()} providers serving ${district.name}, ${district.canton.name}.`
const headingEs = `${category.name} en ${district.name}`
const headingEn = `${category.name} in ${district.name}`
const introEs = `Compare proveedores locales verificados que atienden ${district.name}, ${district.canton.name}.`
const introEn = `Compare verified local providers serving ${district.name}, ${district.canton.name}.`
---

<BaseLayout
  title={pageTitleEs}
  titleEn={pageTitleEn}
  description={pageDescriptionEs}
  descriptionEn={pageDescriptionEn}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-5 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-4 flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-civic bg-canopy-soft text-xl text-canopy">
          {category.icon_emoji ?? '#'}
        </div>
        <div>
          <p class="civic-meta">{district.canton.name} · {district.name}</p>
          <h1 class="text-3xl font-semibold tracking-[-0.5px] text-ink">
            <TranslatedText es={headingEs} en={headingEn} />
          </h1>
        </div>
      </div>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
        <TranslatedText es={introEs} en={introEn} />
      </p>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-6 px-4 py-6 md:grid-cols-[240px_1fr] md:px-6">
    <FilterPanel
      filters={filterOptions}
      sortOptions={sortOptions}
    />

    <div>
      <div class="mb-4 md:hidden">
        <div class="flex gap-2 overflow-x-auto pb-1">
          {
            filterOptions.map((filter) => (
              <a
                class:list={[
                  'shrink-0 rounded-full border px-3 py-1.5 text-xs font-semibold no-underline',
                  filter.active
                    ? 'border-canopy bg-canopy-soft text-canopy'
                    : 'border-rule bg-surface text-ink-2',
                ]}
                href={filter.href}
              >
                <TranslatedText es={filter.es} en={filter.en} />
              </a>
            ))
          }
        </div>
      </div>

      <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <span class="civic-meta">{visibleProviders.length} <TranslatedText es="resultados" en="results" /></span>
        <label class="flex items-center gap-2 text-xs font-semibold text-ink-2">
          <span class="civic-meta"><TranslatedText es="Ordenar" en="Sort" /></span>
          <select class="rounded-civic border border-rule bg-surface px-3 py-1.5 text-xs font-semibold text-ink outline-none" name="sort" data-sort-select>
            {
              sortOptions.map((option) => (
                <option value={option.href} selected={option.active} data-option-es={option.es} data-option-en={option.en}>
                  {option.es}
                </option>
              ))
            }
          </select>
        </label>
      </div>
      {visibleProviders.length > 0 ? (
        <div class="grid gap-3">
          {visibleProviders.map((provider) => <ProviderCard provider={provider} reviewSummary={reviewSummaries.get(provider.id)} />)}
        </div>
      ) : (
        <EmptyState />
      )}
      <div class="mt-8 grid gap-4 rounded-civic border border-rule bg-surface-alt p-4 md:grid-cols-2">
        <div>
          <p class="civic-meta"><TranslatedText es="Distritos cercanos" en="Nearby districts" /></p>
          {
            nearbyDistrictLinks.length > 0 ? (
              <div class="mt-3 flex flex-wrap gap-2">
                {nearbyDistrictLinks.map((nearbyDistrict) => (
                  <a
                    class="rounded-full border border-rule bg-surface px-3 py-1.5 text-xs font-semibold text-ink-2 no-underline hover:border-canopy hover:text-canopy"
                    href={`/${district.canton.slug}/${nearbyDistrict.slug}/`}
                  >
                    {nearbyDistrict.name}
                  </a>
                ))}
              </div>
            ) : (
              <p class="mt-2 text-sm leading-6 text-ink-2">
                <TranslatedText es="Aún no hay distritos cercanos publicados." en="No nearby districts are published yet." />
              </p>
            )
          }
        </div>
        <div>
          <p class="civic-meta"><TranslatedText es="Otras categorías en este distrito" en="Other categories in this district" /></p>
          {
            relatedCategoryLinks.length > 0 ? (
              <div class="mt-3 flex flex-wrap gap-2">
                {relatedCategoryLinks.map((relatedCategory) => (
                  <a
                    class="rounded-full border border-rule bg-surface px-3 py-1.5 text-xs font-semibold text-ink-2 no-underline hover:border-canopy hover:text-canopy"
                    href={`/${district.canton.slug}/${district.slug}/${relatedCategory.slug}/`}
                  >
                    {relatedCategory.name}
                  </a>
                ))}
              </div>
            ) : (
              <p class="mt-2 text-sm leading-6 text-ink-2">
                <TranslatedText
                  es="Publicaremos más categorías cuando haya suficientes proveedores verificados."
                  en="We will publish more categories when there are enough verified providers."
                />
              </p>
            )
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

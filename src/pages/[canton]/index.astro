---
import ProviderSignupCard from '@components/directory/ProviderSignupCard.astro'
import StatsStrip from '@components/directory/StatsStrip.astro'
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategoriesByDistrictId } from '@lib/queries/categories'
import { getCantonBySlug, getCantonStaticPathsAll, getDistrictsByCantonId } from '@lib/queries/geography'
import { getProviderCountByDistrictIds } from '@lib/queries/providers'
import { absoluteUrl } from '@lib/site'
import { t, tpl } from '@lib/i18n'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'
import { placeJsonLd } from '@lib/seo/place'

export const prerender = true

export async function getStaticPaths() {
  return getCantonStaticPathsAll()
}

const cantonSlug = Astro.params.canton ?? ''
const canton = await getCantonBySlug(cantonSlug)

if (!canton) {
  return Astro.redirect('/404')
}

const districts = await getDistrictsByCantonId(canton.id)
const districtSummaries = await Promise.all(
  districts.map(async (district) => ({
    district,
    categoryCount: (await getCategoriesByDistrictId(district.id)).length,
  })),
)
const totalProviders = await getProviderCountByDistrictIds(districts.map((d) => d.id))
const canonical = absoluteUrl(`/${canton.slug}/`, Astro.site)
const breadcrumbs = [
  { name: t('nav.home'), url: absoluteUrl('/', Astro.site) },
  { name: canton.name, url: canonical },
]
const jsonLd = [placeJsonLd({ name: canton.name, url: canonical }), breadcrumbJsonLd(breadcrumbs)]
const pageTitle = tpl('canton.pageTitle', { name: canton.name })
const pageDescription = tpl('canton.pageDescription', { name: canton.name })
const heading = tpl('canton.heading', { name: canton.name })
const intro = tpl('canton.intro', { name: canton.name })
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-6 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
      <p class="civic-meta mt-5">{t('canton.meta')}</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-[-0.5px] text-ink md:text-4xl">
        {heading}
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink-2">
        {intro}
      </p>
      <div class="mt-5">
        <StatsStrip
          items={[
            { label: t('stats.verifiedProviders'), value: totalProviders },
            { label: t('stats.districts'), value: districts.length },
            { label: t('stats.activeCategories'), value: districtSummaries.reduce((total, item) => total + item.categoryCount, 0) },
            { label: t('stats.canton'), value: canton.name },
          ]}
        />
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-6 md:grid-cols-[1fr_280px] md:px-6">
    <div>
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold tracking-[-0.3px]">{t('district.listHeading')}</h2>
        <span class="civic-meta">{districts.length} {t('canton.districtsCount')}</span>
      </div>
      <div class="grid gap-3 md:grid-cols-2">
        {
          districtSummaries.map(({ district, categoryCount }) => (
            <a
              class="civic-card civic-card-hover grid gap-3 p-4 text-ink no-underline"
              href={`/${canton.slug}/${district.slug}/`}
            >
              <span>
                <span class="block text-base font-semibold tracking-[-0.2px]">{district.name}</span>
                <span class="mt-2 block text-sm leading-6 text-ink-2">
                  {`${categoryCount} ${t('canton.categoriesAvailable')}`}
                </span>
              </span>
              <span class="civic-meta block">{t('district.view')}</span>
            </a>
          ))
        }
      </div>

      <div class="mt-8 rounded-civic border border-rule bg-surface-alt p-5">
        <p class="civic-meta">{`${t('canton.aboutPrefix')} ${canton.name}`}</p>
        <p class="mt-3 text-sm leading-7 text-ink-2">
          {tpl('canton.aboutBody', { name: canton.name })}
        </p>
      </div>
    </div>

    <ProviderSignupCard compact />
  </section>
</BaseLayout>

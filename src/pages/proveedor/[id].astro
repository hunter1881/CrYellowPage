---
import { Image } from 'astro:assets'
import ProviderContactBox from '@components/directory/ProviderContactBox.astro'
import ReviewSection from '@components/directory/ReviewSection.astro'
import StickyContactBar from '@components/directory/StickyContactBar.astro'
import Badge from '@components/ui/Badge.astro'
import Breadcrumbs from '@components/seo/Breadcrumbs.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getProviderByRouteSlug, getProviderStaticPaths } from '@lib/queries/providers'
import { getReviewSummaryByProvider } from '@lib/queries/reviews'
import { providerDisplayMeta } from '@lib/providerPresentation'
import { absoluteUrl } from '@lib/site'
import { breadcrumbJsonLd } from '@lib/seo/breadcrumb'
import { localBusinessJsonLd } from '@lib/seo/localBusiness'
import { t, tpl } from '@lib/i18n'

export const prerender = true

export async function getStaticPaths() {
  return getProviderStaticPaths()
}

const routeId = Astro.params.id ?? ''
const provider = await getProviderByRouteSlug(routeId)

if (!provider) {
  return Astro.redirect('/404')
}

const canonical = absoluteUrl(Astro.url.pathname, Astro.site)
const breadcrumbs = [
  { name: t('nav.home'), url: absoluteUrl('/', Astro.site) },
  { name: provider.district.canton.name, url: absoluteUrl(`/${provider.district.canton.slug}/`, Astro.site) },
  {
    name: provider.district.name,
    url: absoluteUrl(`/${provider.district.canton.slug}/${provider.district.slug}/`, Astro.site),
  },
  { name: provider.name, url: canonical },
]
const jsonLd = [
  localBusinessJsonLd({
    name: provider.name,
    phone: provider.phone,
    description: provider.description ?? tpl('provider.jsonLdDesc', { district: provider.district.name }),
    imageUrl: provider.photo_url,
    pageUrl: canonical,
    district: provider.district.name,
    canton: provider.district.canton.name,
    areaServed: [provider.district.name],
  }),
  breadcrumbJsonLd(breadcrumbs),
]
const pageTitle = tpl('provider.pageTitle', { name: provider.name, district: provider.district.name })
const pageDescription = tpl('provider.pageDescription', { name: provider.name, district: provider.district.name, canton: provider.district.canton.name })
const fallbackDescription = tpl('provider.fallbackDesc', { district: provider.district.name })
const [reviewSummary] = await Promise.all([
  getReviewSummaryByProvider(provider.id),
])
const displayMeta = providerDisplayMeta(provider, reviewSummary)
const categoryLabel = provider.categories.map((category) => category.name).join(', ') || t('provider.localService')
const serviceAreas = [provider.district.name, provider.district.canton.name]
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  image={provider.photo_url ?? undefined}
  jsonLd={jsonLd}
  locationLabel={`${provider.district.name} · ${provider.district.canton.name}`}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-3 md:px-6">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </section>

  {/* P2: Back-to-listing button — reads ?from=canton/distrito/categoria from the URL client-side (SSG-compatible) */}
  <div
    class="border-b border-rule-soft bg-surface-alt"
    x-data="{ backHref: null }"
    x-init="
      const from = new URLSearchParams(location.search).get('from');
      if (from && /^[a-z0-9-]{1,80}\/[a-z0-9-]{1,80}\/[a-z0-9-]{1,80}$/.test(from)) {
        backHref = '/' + from + '/';
      }
    "
  >
    <div class="mx-auto max-w-6xl px-4 py-2 md:px-6">
      <a
        x-cloak
        x-show="backHref"
        :href="backHref"
        class="inline-flex items-center gap-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.5px] text-ink-3 underline underline-offset-2 hover:text-canopy"
      >
        <span aria-hidden="true">←</span>
        Volver al listado
      </a>
    </div>
  </div>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 pb-24 pt-6 md:grid-cols-[1fr_320px] md:px-6 md:pb-6">
    <div>
      <div class="mb-6 flex gap-4 md:items-center">
        <div class="h-24 w-24 shrink-0 overflow-hidden rounded-civic border border-rule bg-surface md:h-28 md:w-28">
          {
            provider.photo_url ? (
              <Image
                class="h-full w-full object-cover"
                src={provider.photo_url}
                alt={`Foto de ${provider.name}`}
                width={320}
                height={320}
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-canopy-ink to-canopy font-mono text-[10px] uppercase tracking-[0.5px] text-white/60">
                {t('provider.photo')}
              </div>
            )
          }
        </div>
        <div class="min-w-0">
          <p class="civic-meta">
            {categoryLabel} · {provider.district.canton.name} · {provider.district.name}
          </p>
          <h1 class="mt-1 text-3xl font-semibold leading-tight tracking-[-0.5px] text-ink md:text-4xl">{provider.name}</h1>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <Badge label={t('badge.verified')} />
            {displayMeta.rating !== null && (
              <span class="text-sm text-ink-2"><span class="text-star">★</span> {displayMeta.rating} · {displayMeta.reviewCount} {t('profile.reviews')}</span>
            )}
          </div>
        </div>
      </div>

      <article class="civic-card p-5">
        <p class="civic-meta mb-3">{t('profile.about')}</p>
        <p class="text-sm leading-7 text-ink-2">
          {provider.description ?? fallbackDescription}
        </p>
      </article>

      <dl class="mt-4 grid overflow-hidden rounded-civic border border-rule bg-surface text-sm sm:grid-cols-2 lg:grid-cols-4">
        <div class="border-b border-rule-soft p-4 sm:border-r lg:border-b-0">
          <dt class="civic-meta">{tpl('provider.yearsIn', { canton: provider.district.canton.name })}</dt>
          <dd class="mt-1 text-xl font-bold tracking-[-0.3px] text-ink">{displayMeta.yearsActive ?? '—'}</dd>
        </div>
        <div class="border-b border-rule-soft p-4 sm:border-b-0 lg:border-r">
          <dt class="civic-meta">{t('profile.jobs')}</dt>
          <dd class="mt-1 text-xl font-bold tracking-[-0.3px] text-ink">{displayMeta.completedJobs ?? '—'}</dd>
        </div>
        <div class="border-b border-rule-soft p-4 sm:border-r lg:border-b-0">
          <dt class="civic-meta">{t('profile.rating')}</dt>
          <dd class="mt-1 text-xl font-bold tracking-[-0.3px] text-ink">{displayMeta.rating ?? '—'}</dd>
        </div>
      </dl>

      <section class="civic-card mt-4 p-5">
        <p class="civic-meta mb-3">{t('profile.serviceArea')}</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <p class="mb-2 text-xs font-semibold text-ink-3">{t('profile.primaryLocation')}</p>
            <div class="flex flex-wrap gap-2">
              {serviceAreas.map((area) => <span class="rounded-full border border-rule bg-surface-alt px-3 py-1 text-xs font-semibold text-ink-2">{area}</span>)}
            </div>
          </div>
          <div>
            <p class="mb-2 text-xs font-semibold text-ink-3">{t('profile.listedServices')}</p>
            <div class="flex flex-wrap gap-2">
              {
                provider.categories.map((category) => (
                  <span class="rounded-full bg-canopy-soft px-3 py-1 text-xs font-semibold text-canopy">{category.name}</span>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <ReviewSection
        server:defer
        providerId={provider.id}
        providerName={provider.name}
      >
        <div slot="fallback" class="civic-card mt-4 animate-pulse p-5">
          <div class="h-4 w-32 rounded bg-rule"></div>
          <div class="mt-4 space-y-2">
            <div class="h-3 w-full rounded bg-rule-soft"></div>
            <div class="h-3 w-4/5 rounded bg-rule-soft"></div>
          </div>
        </div>
      </ReviewSection>
    </div>

    <ProviderContactBox
      phone={provider.phone}
      whatsapp={provider.whatsapp}
      acceptsSinpe={displayMeta.acceptsSinpe}
      worksWeekends={displayMeta.worksWeekends}
    />
  </section>
  <StickyContactBar phone={provider.phone} whatsapp={provider.whatsapp} />
</BaseLayout>

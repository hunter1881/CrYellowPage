---
import { actions, isInputError } from 'astro:actions'
import Alert from '@components/ui/Alert.astro'
import ProviderRegistrationForm from '@components/directory/ProviderRegistrationForm.astro'
import DirectoryLayout from '@layouts/DirectoryLayout.astro'
import { getCategories } from '@lib/queries/categories'
import { getCantonsWithDistricts } from '@lib/queries/geography'
import { getPaymentMethods } from '@lib/queries/paymentMethods'
import { absoluteUrl } from '@lib/site'
import { t } from '@lib/i18n'

export const prerender = false

const canonical = absoluteUrl('/register-provider/', Astro.site)
const [cantons, categories, paymentMethods] = await Promise.all([getCantonsWithDistricts(), getCategories(), getPaymentMethods()])
const result = Astro.getActionResult(actions.registerProvider)
const inputErrors = isInputError(result?.error) ? result.error.fields : {}
---

<DirectoryLayout
  title="Registrar proveedor | El Contactico"
  description="Registre su negocio local para aparecer en El Contactico por cantón, distrito y categoría."
  canonical={canonical}
  meta={t('register.forProviders')}
  heading={t('register.title')}
  intro={t('register.subheading')}
  headerPy="py-8"
>

  <section class="mx-auto grid max-w-6xl gap-6 px-4 py-8 md:grid-cols-[1fr_320px] md:px-6">
    <div>
      {result && !result.error && (
        <Alert variant="success" class="mb-4">
          <p class="font-semibold">{t('register.sent')}</p>
          <p>{t('register.successBody')}</p>
        </Alert>
      )}
      {result?.error && !isInputError(result.error) && (
        <Alert variant="error" class="mb-4">{result.error.message}</Alert>
      )}
      <ProviderRegistrationForm cantons={cantons} categories={categories} paymentMethods={paymentMethods} inputErrors={inputErrors} />
    </div>

    <aside class="civic-card h-fit p-5">
      <p class="civic-meta mb-3">{t('register.process')}</p>
      <ol class="grid gap-3 text-sm leading-6 text-ink-2">
        <li><strong class="text-ink">1.</strong> {t('register.step1')}</li>
        <li><strong class="text-ink">2.</strong> {t('register.step2')}</li>
        <li><strong class="text-ink">3.</strong> {t('register.step3')}</li>
      </ol>
      <div class="mt-5 rounded-civic border border-rule bg-surface-alt p-4 text-sm leading-6 text-ink-2">
        {t('register.curationNote')}
      </div>
    </aside>
  </section>
</DirectoryLayout>

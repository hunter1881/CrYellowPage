---
import { actions, isInputError } from 'astro:actions'
import ProviderRegistrationForm from '@components/directory/ProviderRegistrationForm.astro'
import TranslatedText from '@components/i18n/TranslatedText.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategories } from '@lib/queries/categories'
import { getCantonsWithDistricts } from '@lib/queries/geography'
import { absoluteUrl } from '@lib/site'

export const prerender = false

const canonical = absoluteUrl('/registrar-proveedor/', Astro.site)
const [cantons, categories] = await Promise.all([getCantonsWithDistricts(), getCategories()])
const result = Astro.getActionResult(actions.registerProvider)
const inputErrors = isInputError(result?.error) ? result.error.fields : {}
---

<BaseLayout
  title="Registrar proveedor | DirectorioLocal CR"
  titleEn="Register Provider | DirectorioLocal CR"
  description="Registre su negocio local para aparecer en DirectorioLocal CR por cantón, distrito y categoría."
  descriptionEn="Register your local business to appear in DirectorioLocal CR by canton, district, and category."
  canonical={canonical}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-8 md:px-6">
      <p class="civic-meta"><TranslatedText es="Para proveedores" en="For providers" /></p>
      <h1 class="mt-2 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.6px] text-ink md:text-[40px]">
        <TranslatedText es="Registrá tu servicio local" en="Register your local service" />
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-ink-2">
        <TranslatedText
          es="Complete la solicitud para revisión. Validamos los datos antes de publicar cualquier proveedor en el directorio."
          en="Complete the application for review. We validate details before publishing any provider in the directory."
        />
      </p>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-6 px-4 py-8 md:grid-cols-[1fr_320px] md:px-6">
    <div>
      {
        result && !result.error && (
          <div class="mb-4 rounded-civic border border-canopy bg-canopy-soft p-4 text-sm leading-6 text-canopy-ink">
            <p class="font-semibold"><TranslatedText es="Solicitud enviada" en="Application sent" /></p>
            <p>
              <TranslatedText
                es="Recibimos la información. Revisaremos el proveedor antes de publicarlo."
                en="We received the information. We will review the provider before publishing it."
              />
            </p>
          </div>
        )
      }
      {
        result?.error && !isInputError(result.error) && (
          <div class="mb-4 rounded-civic border border-red-200 bg-red-50 p-4 text-sm leading-6 text-red-800">
            {result.error.message}
          </div>
        )
      }
      <ProviderRegistrationForm cantons={cantons} categories={categories} inputErrors={inputErrors} />
    </div>

    <aside class="civic-card h-fit p-5">
      <p class="civic-meta mb-3"><TranslatedText es="Proceso" en="Process" /></p>
      <ol class="grid gap-3 text-sm leading-6 text-ink-2">
        <li><strong class="text-ink">1.</strong> <TranslatedText es="Enviás la solicitud." en="You send the application." /></li>
        <li><strong class="text-ink">2.</strong> <TranslatedText es="Revisamos zona, categoría y contacto." en="We review area, category, and contact details." /></li>
        <li><strong class="text-ink">3.</strong> <TranslatedText es="Publicamos el perfil cuando esté verificado." en="We publish the profile once verified." /></li>
      </ol>
      <div class="mt-5 rounded-civic border border-rule bg-surface-alt p-4 text-sm leading-6 text-ink-2">
        <TranslatedText
          es="Por ahora la solicitud no crea una página pública automáticamente. Eso evita spam y mantiene el directorio curado."
          en="For now, the application does not create a public page automatically. This prevents spam and keeps the directory curated."
        />
      </div>
    </aside>
  </section>
</BaseLayout>

---
import CategoryGrid from '@components/directory/CategoryGrid.astro'
import DistrictLinkList from '@components/directory/DistrictLinkList.astro'
import ProviderCard from '@components/directory/ProviderCard.astro'
import ProviderSignupCard from '@components/directory/ProviderSignupCard.astro'
import SearchBar from '@components/directory/SearchBar.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCategoriesWithCountsByDistrictId } from '@lib/queries/categories'
import { getCantonsWithDistricts, getFirstActiveDistrict } from '@lib/queries/geography'
import { getListingStaticPaths, getRecentProviders } from '@lib/queries/providers'
import { getReviewSummariesByProviderIds } from '@lib/queries/reviews'
import { absoluteUrl, defaultDescription, siteName } from '@lib/site'
import { websiteJsonLd } from '@lib/seo/website'
import { t } from '@lib/i18n'

export const prerender = true

const [cantons, firstActiveDistrict, recentProviders, publishedListingPaths] = await Promise.all([
  getCantonsWithDistricts(),
  getFirstActiveDistrict(),
  getRecentProviders(3),
  getListingStaticPaths(),
])

const publishedListings = publishedListingPaths.map(
  (path) => `${path.params.canton}/${path.params.distrito}/${path.params.categoria}`,
)

const currentCanton = firstActiveDistrict
  ? cantons.find((c) => c.id === firstActiveDistrict.canton.id) ?? cantons[0] ?? null
  : (cantons[0] ?? null)
const currentDistrict = firstActiveDistrict ?? currentCanton?.districts[0] ?? null
const currentCategories = currentDistrict
  ? await getCategoriesWithCountsByDistrictId(currentDistrict.id)
  : []

const reviewSummaries = recentProviders.length > 0
  ? await getReviewSummariesByProviderIds(recentProviders.map((p) => p.id))
  : new Map()

const canonical = absoluteUrl('/', Astro.site)
const jsonLd = websiteJsonLd({ name: siteName, url: canonical })
const districtsLabel = (count: number) =>
  `${count} ${count === 1 ? t('canton.district') : t('canton.districtsCount')} disponible${count === 1 ? '' : 's'}`
---

<BaseLayout
  title="Servicios Locales en Costa Rica | DirectorioLocal CR"
  description={defaultDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="border-b border-rule bg-surface-alt">
    <div class="mx-auto max-w-6xl px-4 py-8 md:px-6 md:py-12">
      <h1 class="mb-5 text-3xl font-bold leading-tight tracking-[-0.6px] text-ink md:text-[42px]">
        {t('home.tagline')}
      </h1>
      <SearchBar
        cantons={cantons}
        categories={currentCategories}
        publishedListings={publishedListings}
        transition:persist
      />
      <ul class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-2">
        <li class="flex items-center gap-1.5"><span class="font-semibold text-canopy">✓</span> {t('stats.verifiedProviders')}</li>
        <li class="flex items-center gap-1.5"><span class="font-semibold text-canopy">✓</span> {t('home.whatsapp')}</li>
        <li class="flex items-center gap-1.5"><span class="font-semibold text-canopy">✓</span> {t('home.featureFilter')}</li>
        <li class="flex items-center gap-1.5"><span class="font-semibold text-canopy">✓</span> {t('home.featureFree')}</li>
      </ul>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-8 md:grid-cols-[240px_1fr] md:px-6">
    <aside class="order-2 grid gap-6 md:order-1" id="home-district-aside"
      data-canton-slug={currentCanton?.slug ?? ''}
      data-district-slug={currentDistrict?.slug ?? ''}
      data-i18n-heading={t('district.listHeading')}
      data-i18n-view={t('district.view')}>
      {
        currentCanton && (
          <div id="home-district-list">
            <DistrictLinkList
              cantonSlug={currentCanton.slug}
              districts={currentCanton.districts}
              activeDistrictSlug={currentDistrict?.slug}
            />
          </div>
        )
      }
      <ProviderSignupCard compact />
    </aside>

    <script is:inline type="application/json" data-home-cantons set:html={JSON.stringify(cantons.map((c) => ({ slug: c.slug, name: c.name, districts: c.districts.map((d) => ({ slug: d.slug, name: d.name, id: d.id })) })))} />

    <script is:inline>
      document.addEventListener('districtSelected', (event) => {
        const opt = event.detail
        const listContainer = document.getElementById('home-district-list')
        if (!listContainer) return

        if (!opt) {
          // cleared — restore default view link
          listContainer.innerHTML = ''
          return
        }

        const allCantons = JSON.parse(document.querySelector('[data-home-cantons]')?.textContent ?? '[]')
        const canton = allCantons.find((c) => c.slug === opt.cs)
        if (!canton) return

        // Re-render district list for the selected canton
        const aside = document.getElementById('home-district-aside')
        const i18nHeading = aside?.dataset.i18nHeading ?? ''
        const links = canton.districts.map((d, i) => {
          const active = d.slug === opt.ds
          const border = i < canton.districts.length - 1 ? 'border-b border-rule-soft' : ''
          const activeStyle = active ? 'color:#0E5A3F;' : ''
          const dot = active ? '<span class="mr-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-canopy"></span>' : ''
          return `<a class="district-lnk flex items-center py-2.5 no-underline transition-colors ${border}" style="${activeStyle}" href="/${canton.slug}/${d.slug}/">
            ${dot}<span class="flex-1 text-[13.5px] text-ink">${d.name}</span>
            <span class="ml-2 font-mono text-[11px] uppercase tracking-[0.5px] text-ink-3" style="font-family:ui-monospace,monospace;">ver</span>
          </a>`
        }).join('')
        const eyebrow = `<div class="mb-2.5 inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.6px] text-ink-3">
          <span class="text-canopy" style="font-family:ui-monospace,monospace;">03</span>
          <span class="h-px w-4 bg-rule" style="display:inline-block;height:1px;width:16px;background:#DDD9CC;"></span>
          ${i18nHeading} · ${canton.name}
        </div>`
        listContainer.innerHTML = `<div class="rounded-civic-lg border border-rule bg-surface shadow-civic"><div class="px-[18px] pt-[18px]">${eyebrow}</div><div class="px-[18px] pb-[18px]">${links}</div></div>`
      })
    </script>

    <div id="districts" class="order-1 md:order-2">
      {
        currentDistrict && (
          <section id="categories">
            <div class="mb-4 flex items-baseline justify-between">
              <h2 class="text-xl font-semibold tracking-[-0.3px] text-ink">
                {`${t('home.categoriesIn')} ${currentDistrict.name}`}
              </h2>
              <span class="civic-meta">{currentCategories.length} {t('home.categoriesUnit')}</span>
            </div>
            <CategoryGrid categories={currentCategories} basePath={`/${currentCanton!.slug}/${currentDistrict.slug}`} />
          </section>
        )
      }

      {recentProviders.length > 0 && (
        <section class="mt-10">
          <div class="mb-4 flex items-baseline justify-between">
            <h2 class="text-xl font-semibold tracking-[-0.3px] text-ink">
              {t('home.lastVerified')}
            </h2>
            {currentCanton && currentDistrict && (
              <a class="civic-meta text-canopy no-underline hover:underline" href={`/${currentCanton.slug}/${currentDistrict.slug}/`}>
                {t('home.seeAll')}
              </a>
            )}
          </div>
          <div class="grid gap-4">
            {recentProviders.map((provider) => (
              <ProviderCard provider={provider} reviewSummary={reviewSummaries.get(provider.id)} />
            ))}
          </div>
        </section>
      )}

      <section id="cantones" class="mt-10 hidden" aria-hidden="true">
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-xl font-semibold tracking-[-0.3px] text-ink">
            {t('home.browseCanton')}
          </h2>
          <span class="civic-meta">{cantons.length} {t('home.cantonsUnit')}</span>
        </div>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
          {
            cantons.map((canton) => (
              <article class="civic-card civic-card-hover p-4">
                <h3 class="text-base font-semibold tracking-[-0.2px]">
                  <a class="text-ink no-underline hover:text-canopy" href={`/${canton.slug}`}>
                    {canton.name}
                  </a>
                </h3>
                <p class="civic-meta mt-2">
                  {districtsLabel(canton.districts.length)}
                </p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </section>

  <script is:inline>
    function maybeShowCantons() {
      if (window.location.hash === '#cantones') {
        const section = document.getElementById('cantones')
        if (section) {
          section.classList.remove('hidden')
          section.removeAttribute('aria-hidden')
          section.scrollIntoView({ behavior: 'smooth', block: 'start' })
        }
      }
    }
    maybeShowCantons()
    window.addEventListener('hashchange', maybeShowCantons)
  </script>
</BaseLayout>

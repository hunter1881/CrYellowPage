---
import BaseLayout from '@layouts/BaseLayout.astro'
import Alert from '@components/ui/Alert.astro'
import Button from '@components/ui/Button.astro'
import Checkbox from '@components/ui/Checkbox.astro'
import ChipSelect from '@components/ui/ChipSelect.astro'
import Input from '@components/ui/Input.astro'
import Textarea from '@components/ui/Textarea.astro'
import { createSupabaseServerClient } from '@lib/supabaseServer'
import { getCategories } from '@lib/queries/categories'
import { getPaymentMethods, selectedIncludesSinpe } from '@lib/queries/paymentMethods'
import { absoluteUrl } from '@lib/site'
import { t } from '@lib/i18n'

export const prerender = false

const { id: providerId } = Astro.params
if (!providerId) return Astro.redirect('/account/')

const supabase = createSupabaseServerClient(Astro.request, Astro.response.headers)
const { data: { user } } = await supabase.auth.getUser()

if (!user) return Astro.redirect('/account/login/')

// Load provider — RLS enforces ownership
const { data: provider, error: providerError } = await supabase
  .from('providers')
  .select('id, name, description, phone, whatsapp, accepts_sinpe, works_weekends, years_active, response_time_minutes, owner_id')
  .eq('id', providerId)
  .eq('owner_id', user.id)
  .maybeSingle()

if (providerError || !provider) return Astro.redirect('/account/')

// Current categories for this provider
const { data: currentCategories } = await supabase
  .from('provider_categories')
  .select('category_id')
  .eq('provider_id', providerId)

const currentCategoryIds = new Set((currentCategories ?? []).map((row) => row.category_id))
const [allCategories, allPaymentMethods] = await Promise.all([getCategories(), getPaymentMethods()])

// Current payment methods for this provider
const { data: currentProviderPayments } = await supabase
  .from('provider_payment_methods')
  .select('payment_method_id')
  .eq('provider_id', providerId)
const currentPaymentMethodIds = new Set((currentProviderPayments ?? []).map((row) => row.payment_method_id))
const currentPaymentSlugs = allPaymentMethods
  .filter((pm) => currentPaymentMethodIds.has(pm.id))
  .map((pm) => pm.slug)

const canonical = absoluteUrl(`/account/edit/${providerId}/`, Astro.site)

let successMessage: string | null = null
let errorMessage: string | null = null

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()

  const description = String(formData.get('description') ?? '').trim() || null
  const phone = String(formData.get('phone') ?? '').trim()
  const whatsapp = String(formData.get('whatsapp') ?? '').trim() || null
  const paymentMethodSlugs = formData.getAll('paymentMethodSlugs').map(String).filter(Boolean)
  const acceptsSinpe = selectedIncludesSinpe(paymentMethodSlugs)
  const worksWeekends = formData.get('worksWeekends') === 'on'
  const yearsActive = Math.max(0, parseInt(String(formData.get('yearsActive') ?? '0'), 10) || 0)
  const responseTimeMinutes = parseInt(String(formData.get('responseTimeMinutes') ?? ''), 10)
  const selectedCategoryIds = formData.getAll('categoryIds').map(String).filter(Boolean)

  if (!phone) {
    errorMessage = 'El teléfono es obligatorio.'
  } else if (selectedCategoryIds.length === 0 || selectedCategoryIds.length > 4) {
    errorMessage = 'Seleccioná entre 1 y 4 categorías.'
  } else {
    const validCategories = new Set(allCategories.map((c) => c.id))
    const allValid = selectedCategoryIds.every((id) => validCategories.has(id))
    if (!allValid) {
      errorMessage = 'Una o más categorías no son válidas.'
    } else {
      const { error: updateError } = await supabase
        .from('providers')
        .update({
          description,
          phone,
          whatsapp,
          accepts_sinpe: acceptsSinpe,
          works_weekends: worksWeekends,
          years_active: yearsActive,
          response_time_minutes: Number.isFinite(responseTimeMinutes) && responseTimeMinutes > 0
            ? responseTimeMinutes
            : null,
        })
        .eq('id', providerId)
        .eq('owner_id', user.id)

      if (updateError) {
        errorMessage = 'No se pudieron guardar los cambios. Intentá de nuevo.'
      } else {
        // Sync categories: delete all then re-insert
        await supabase.from('provider_categories').delete().eq('provider_id', providerId)
        if (selectedCategoryIds.length > 0) {
          await supabase.from('provider_categories').insert(
            selectedCategoryIds.map((categoryId) => ({ provider_id: providerId, category_id: categoryId }))
          )
        }
        // Sync payment methods: delete all then re-insert by slug→id lookup
        await supabase.from('provider_payment_methods').delete().eq('provider_id', providerId)
        if (paymentMethodSlugs.length > 0) {
          const validSlugMap = new Map(allPaymentMethods.map((pm) => [pm.slug, pm.id]))
          const paymentRows = paymentMethodSlugs
            .filter((slug) => validSlugMap.has(slug))
            .map((slug) => ({ provider_id: providerId, payment_method_id: validSlugMap.get(slug)! }))
          if (paymentRows.length > 0) {
            await supabase.from('provider_payment_methods').insert(paymentRows)
          }
        }

        successMessage = 'Cambios guardados.'
        // Refresh current category list
        const { data: refreshed } = await supabase
          .from('provider_categories')
          .select('category_id')
          .eq('provider_id', providerId)
        currentCategoryIds.clear()
        for (const row of refreshed ?? []) currentCategoryIds.add(row.category_id)
      }
    }
  }
}
---

<BaseLayout
  title={`Editar ${provider.name} | DirectorioLocal CR`}
  description="Edite los datos de su perfil de proveedor."
  canonical={canonical}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-5 md:px-6">
      <nav class="flex items-center gap-2 text-sm text-ink-3">
        <a class="hover:text-ink" href="/account/">{t('edit.myAccount')}</a>
        <span>/</span>
        <span class="text-ink">{provider.name}</span>
      </nav>
      <h1 class="mt-2 text-2xl font-semibold tracking-[-0.5px] text-ink">
        {t('edit.title')}
      </h1>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-8 md:px-6">
    {successMessage && (
      <Alert variant="success" class="mb-5">{t('edit.saved')}</Alert>
    )}
    {errorMessage && (
      <Alert variant="error" class="mb-5">{errorMessage}</Alert>
    )}

    <form class="civic-card grid gap-6 p-6" method="POST">

      <div class="grid gap-4 sm:grid-cols-2">
        <Input label={t('edit.phone')} name="phone" type="tel" required value={provider.phone} />
        <Input label="WhatsApp" name="whatsapp" type="tel" hint={t('common.optional')} value={provider.whatsapp ?? ''} />
      </div>

      <Textarea
        label={t('edit.description')}
        name="description"
        rows={4}
        maxlength={500}
        value={provider.description}
        hint={t('edit.descriptionHint')}
      />

      <div class="grid gap-4 sm:grid-cols-2">
        <Input label={t('edit.yearsActive')} name="yearsActive" type="number" value={provider.years_active ?? ''} />
        <Input label={t('edit.responseTime')} name="responseTimeMinutes" type="number" placeholder="ej. 30" value={provider.response_time_minutes ?? ''} />
      </div>

      <ChipSelect
        name="categoryIds"
        label={t('edit.categories')}
        options={allCategories.map((c) => ({ value: c.id, label: `${c.icon_emoji ? `${c.icon_emoji} ` : ''}${c.name}` }))}
        selected={[...currentCategoryIds]}
        max={4}
        required
        placeholder="Buscar categoría de servicio…"
      />

      <ChipSelect
        name="paymentMethodSlugs"
        label="Métodos de pago aceptados"
        options={allPaymentMethods.map((pm) => ({ value: pm.slug, label: pm.name }))}
        selected={currentPaymentSlugs}
        max={11}
        placeholder="Buscar método de pago…"
      />

      <fieldset class="grid gap-2">
        <legend class="text-sm font-semibold text-ink">{t('edit.options')}</legend>
        <Checkbox name="worksWeekends" value="on" label={t('edit.worksWeekends')} variant="plain" checked={provider.works_weekends ?? false} />
      </fieldset>

      <div class="flex gap-3">
        <Button type="submit">{t('edit.save')}</Button>
        <Button variant="outline" href="/account/">{t('edit.cancel')}</Button>
      </div>

    </form>
  </section>
</BaseLayout>

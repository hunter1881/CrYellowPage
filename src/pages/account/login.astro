---
import Alert from '@components/ui/Alert.astro'
import Button from '@components/ui/Button.astro'
import Input from '@components/ui/Input.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { createSupabaseServerClient } from '@lib/supabaseServer'
import { absoluteUrl } from '@lib/site'
import { t } from '@lib/i18n'

export const prerender = false

const supabase = createSupabaseServerClient(Astro.request, Astro.response.headers)
const { data: { user } } = await supabase.auth.getUser()

// Already logged in → redirect to dashboard
if (user) {
  return Astro.redirect('/account/')
}

const canonical = absoluteUrl('/account/login/', Astro.site)

let errorMessage: string | null = null
let successMessage: string | null = null

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const email = String(formData.get('email') ?? '').trim().toLowerCase()

  if (!email || !email.includes('@')) {
    errorMessage = t('login.validEmailError')
  } else {
    // Use the current request's origin so the link works in dev, staging, and prod
    const redirectTo = new URL('/account/', Astro.url.origin).href
    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: redirectTo },
    })
    if (error) {
      errorMessage = t('login.sendError')
    } else {
      successMessage = email
    }
  }
}
---

<BaseLayout
  title="Iniciar sesión | DirectorioLocal CR"
  description="Ingresá a tu panel de proveedor para administrar tu perfil en DirectorioLocal CR."
  canonical={canonical}
>
  <section class="flex min-h-[60vh] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <p class="civic-meta">{t('login.meta')}</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-[-0.5px] text-ink">
          {t('login.title')}
        </h1>
        <p class="mt-2 text-sm text-ink-2">
          {t('login.subtitle')}
        </p>
      </div>

      {successMessage && (
        <Alert variant="success" class="mb-5">
          <p class="font-semibold">{t('login.checkEmail')}</p>
          {`${t('login.successBodyPrefix')} ${successMessage}. ${t('login.successBodySuffix')}`}
        </Alert>
      )}

      {errorMessage && (
        <Alert variant="error" class="mb-5">{errorMessage}</Alert>
      )}

      {!successMessage && (
        <form class="civic-card grid gap-4 p-5" method="POST">
          <Input label={t('login.emailLabel')} name="email" type="email" required placeholder="you@email.com" />
          <Button type="submit" full class="py-3">{t('login.sendLink')}</Button>
        </form>
      )}

      <p class="mt-5 text-center text-xs text-ink-3">
        {t('login.noProfile')}
        <a class="underline hover:text-ink" href="/register-provider">
          {t('login.registerService')}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

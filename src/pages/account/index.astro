---
import Alert from '@components/ui/Alert.astro'
import Badge from '@components/ui/Badge.astro'
import Button from '@components/ui/Button.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { createSupabaseServerClient } from '@lib/supabaseServer'
import { absoluteUrl } from '@lib/site'
import { providerUrl } from '@lib/slug'
import { t } from '@lib/i18n'

export const prerender = false

const supabase = createSupabaseServerClient(Astro.request, Astro.response.headers)
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/account/login/')
}

const canonical = absoluteUrl('/account/', Astro.site)

// Load the provider owned by this user (if any)
const { data: provider } = await supabase
  .from('providers')
  .select('id, name, verified, description, phone, created_at, district_id')
  .eq('owner_id', user.id)
  .maybeSingle()

// Load pending registration (if any)
const { data: registration } = await supabase
  .from('provider_registrations')
  .select('id, business_name, status, created_at')
  .eq('email', user.email ?? '')
  .order('created_at', { ascending: false })
  .limit(1)
  .maybeSingle()
---

<BaseLayout
  title="Mi cuenta | DirectorioLocal CR"
  description="Administre su perfil de proveedor en DirectorioLocal CR."
  canonical={canonical}
>
  <section class="border-b border-rule bg-surface">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-5 md:px-6">
      <div>
        <p class="civic-meta">{t('account.meta')}</p>
        <h1 class="mt-1 text-2xl font-semibold tracking-[-0.5px] text-ink">
          {t('account.title')}
        </h1>
      </div>
      <form method="POST" action="/account/logout">
        <Button variant="outline" type="submit">{t('account.signOut')}</Button>
      </form>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8 md:px-6">
    <div class="grid gap-5 md:grid-cols-2">

      {/* Active provider profile */}
      {provider ? (
        <div class="civic-card p-5">
          <div class="mb-4 flex items-start justify-between gap-3">
            <div>
              <p class="civic-meta">{t('account.publishedProfile')}</p>
              <h2 class="mt-1 text-lg font-semibold text-ink">{provider.name}</h2>
            </div>
            {provider.verified
              ? <Badge label="Verificado" variant="verified" />
              : <Badge label={t('common.pending')} variant="pending" />
            }
          </div>
          <p class="text-sm leading-6 text-ink-2">{provider.description ?? '—'}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <Button variant="outline" href={`/account/edit/${provider.id}`} class="gap-2">
              {t('account.editProfile')}
            </Button>
            <Button variant="ghost" href={providerUrl(provider.id, provider.name)} class="gap-2" target="_blank" rel="noopener">
              {t('account.viewPublic')}
            </Button>
          </div>
        </div>
      ) : (
        <div class="civic-card flex flex-col items-center justify-center gap-3 p-8 text-center">
          <p class="text-sm text-ink-2">
            Aún no tenés un perfil activo en el directorio.
          </p>
          <Button variant="primary" href="/register-provider" class="text-sm">
            {t('common.registerService')}
          </Button>
        </div>
      )}

      {/* Registration status */}
      {registration && (
        <div class="civic-card p-5">
          <p class="civic-meta mb-2">{t('account.applicationSent')}</p>
          <p class="text-lg font-semibold text-ink">{registration.business_name}</p>
          <div class="mt-3 flex items-center gap-2">
            {registration.status === 'pending' && (
              <Badge label={t('account.underReview')} variant="pending" />
            )}
            {registration.status === 'approved' && (
              <Badge label={t('account.approved')} variant="verified" />
            )}
            {registration.status === 'rejected' && (
              <Badge label={t('account.rejected')} variant="pending" />
            )}
          </div>
          <p class="mt-3 text-sm text-ink-3">
            Revisamos las solicitudes en 1–2 días hábiles.
          </p>
        </div>
      )}

    </div>
  </section>
</BaseLayout>
